        // ---- 形态转换提示 ----
        function updateTransitionTip(records) {
            if (records.length < 2) {
                document.getElementById('transitionTip').textContent = '数据不足';
                return;
            }
            const forms = records.map(r => r.form);
            const trans = {};
            for (let i = 0; i < forms.length - 1; i++) {
                const cur = forms[i];
                const nxt = forms[i+1];
                if (!trans[cur]) trans[cur] = {};
                trans[cur][nxt] = (trans[cur][nxt] || 0) + 1;
            }
            const lastForm = forms[0];
            if (!trans[lastForm] || Object.keys(trans[lastForm]).length === 0) {
                document.getElementById('transitionTip').textContent = '暂无转换数据';
                return;
            }
            let maxCount = 0, maxForm = null;
            for (let f in trans[lastForm]) {
                if (trans[lastForm][f] > maxCount) {
                    maxCount = trans[lastForm][f];
                    maxForm = f;
                }
            }
            const total = Object.values(trans[lastForm]).reduce((a,b) => a+b, 0);
            const prob = (maxCount / total * 100).toFixed(1);
            document.getElementById('transitionTip').textContent = `当前形态 ${lastForm} → 最可能 ${maxForm} (概率 ${prob}%)`;
        }

