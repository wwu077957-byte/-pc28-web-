<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>PC28 多情120算法 · 120🇨🇦</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --bg: #0a0c10; --bg2: rgba(22,27,36,0.75); --text: #e8edf5;
            --text2: #8892a8; --text3: #5a6a7a; --border: rgba(38,45,58,0.3);
            --gold: #f7d44a; --success: #3fb950; --danger: #f85149;
            --accent: #58a9ff; --card-bg: rgba(22,27,36,0.5);
            --shadow: 0 8px 32px rgba(0,0,0,0.5); --radius: 16px; --radius-sm: 12px;
        }
        [data-theme="light"] {
            --bg: #e8ecf1; --bg2: rgba(255,255,255,0.8); --text: #1a1a2e;
            --text2: #5a6a7a; --text3: #8a9aaa; --border: rgba(180,190,200,0.4);
            --card-bg: rgba(255,255,255,0.7); --shadow: 0 8px 32px rgba(0,0,0,0.08);
        }
        body { font-family: -apple-system, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 12px 10px 30px; transition: background 0.3s; position: relative; overflow-x: hidden; }
        #bgCanvas { position: fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; opacity:0.7; }
        .app { max-width: 820px; margin:0 auto; position:relative; z-index:1; }
        .glass {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 12px 14px;
            margin-bottom: 10px;
            box-shadow: var(--shadow);
        }
        .glass-title { font-size: 14px; font-weight: 600; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center; }
        .flex { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
        .flex-between { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 6px; }
        .btn {
            padding: 5px 14px; border-radius: 30px; font-size: 12px; font-weight: 600;
            border: 1px solid var(--border); background: var(--bg2); color: var(--text);
            cursor: pointer; transition: all 0.2s;
        }
        .btn:hover { transform: scale(0.96); opacity: 0.8; }
        .btn-success { background: var(--success); color: #0a0c10; border-color: var(--success); }
        .btn-danger { background: var(--danger); color: #fff; border-color: var(--danger); }
        .btn-sm { padding: 3px 10px; font-size: 11px; }
        select {
            background: var(--bg2); border: 1px solid var(--border); color: var(--text);
            padding: 5px 10px; border-radius: var(--radius-sm); font-size: 13px; outline: none;
            cursor: pointer; max-width: 280px; min-width: 180px;
        }
        select:focus { border-color: var(--accent); }
        .ball { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 50%; font-weight: 700; font-size: 14px; color: #fff; flex-shrink: 0; }
        .ball-0 { background: linear-gradient(135deg,#4a9eff,#2d7fd3); }
        .ball-1 { background: linear-gradient(135deg,#4ac9a9,#2da88a); }
        .ball-2 { background: linear-gradient(135deg,#f7b84a,#d4922e); }
        .ball-3 { background: linear-gradient(135deg,#d46ac9,#b04da8); }
        .ball-4 { background: linear-gradient(135deg,#ff6b6b,#d94444); }
        .tag { padding: 2px 10px; border-radius: 30px; font-size: 11px; font-weight: 600; display: inline-block; }
        .tag-big { background: rgba(247,184,74,0.2); color: #f7b84a; border:1px solid rgba(247,184,74,0.15); }
        .tag-small { background: rgba(74,201,169,0.2); color: #4ac9a9; border:1px solid rgba(74,201,169,0.15); }
        .tag-odd { background: rgba(212,106,201,0.2); color: #d46ac9; border:1px solid rgba(212,106,201,0.15); }
        .tag-even { background: rgba(74,158,255,0.2); color: #4a9eff; border:1px solid rgba(74,158,255,0.15); }
        .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 6px 8px; text-align: center; min-width: 60px; }
        .stat-card .num { font-size: 18px; font-weight:700; color: var(--gold); }
        .stat-card .label { font-size: 10px; color: var(--text3); }
        .grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
        @media (max-width:600px){ .grid-4 { grid-template-columns:1fr 1fr; } }
        .result-box { background: var(--bg2); border-radius: var(--radius-sm); padding: 10px 12px; border: 1px solid var(--border); text-align: center; margin-top: 4px; }
        .result-box .big { font-size: 24px; font-weight: 700; color: var(--gold); }
        .result-box .sub { font-size: 13px; color: var(--text2); margin-top: 3px; }
        .result-box .kill { color: var(--danger); font-weight: 700; font-size: 18px; }
        .result-box .buy { color: var(--success); font-weight: 700; font-size: 18px; }
        .toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--card-bg); backdrop-filter: blur(18px); color: var(--text); padding: 6px 18px; border-radius: 30px; font-size: 13px; border: 1px solid var(--border); opacity: 0; transition: all 0.4s; z-index: 999; pointer-events: none; }
        .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
        .table-wrap { overflow-x:auto; margin-top:4px; }
        table { width:100%; border-collapse:collapse; font-size:12px; }
        th, td { padding:4px 6px; text-align:center; border-bottom:1px solid var(--border); }
        th { color: var(--text3); font-size:11px; }
        .status-badge { display:inline-block; padding:2px 8px; border-radius:20px; font-size:11px; font-weight:600; }
        .status-badge.hit { background:rgba(63,185,80,0.2); color:var(--success); }
        .status-badge.miss { background:rgba(248,81,73,0.2); color:var(--danger); }
        .countdown-timer { font-size: 20px; font-weight:700; background: linear-gradient(135deg,#f7d44a,#f7971e); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .progress-bar { width:100%; height:3px; background:var(--border); border-radius:4px; margin-top:4px; overflow:hidden; }
        .progress-bar .fill { height:100%; background:linear-gradient(90deg,#f7971e,#ffd200); border-radius:4px; transition:width 1s; }
        .algo-count { font-size: 11px; color: var(--text3); margin-left: 4px; }
        .input-group { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
        .input-group input { width: 50px; padding: 4px 6px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg2); color: var(--text); text-align: center; font-size: 16px; }
        .input-group label { font-size: 12px; color: var(--text2); }
        .manual-panel { display: none; }
        .auto-status { font-size: 11px; color: var(--text3); cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
        .auto-status:hover { color: var(--gold); }
    </style>
</head>
<body>
<canvas id="bgCanvas"></canvas>
<div id="toast" class="toast">已复制</div>
<div class="app">

    <!-- 顶部 -->
    <div class="glass" style="padding:8px 12px;">
        <div class="flex-between">
            <span style="font-size:18px;font-weight:800;background:linear-gradient(135deg,#f7971e,#ffd200);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">🎯 PC28 算法库</span>
            <div class="flex">
                <span id="headerTime" style="font-size:12px;color:var(--text2);">--:--</span>
                <button class="btn btn-sm" id="themeToggle">🌓</button>
                <button class="btn btn-sm btn-success" id="refreshBtn">🔄</button>
                <span class="auto-status" id="autoStatus">▶️ 30s</span>
            </div>
        </div>
    </div>

    <!-- 算法选择 -->
    <div class="glass">
        <div class="flex" style="justify-content:space-between;flex-wrap:wrap;gap:4px;">
            <div class="flex" style="flex:1;min-width:200px;">
                <span style="font-size:13px;color:var(--text2);font-weight:600;">算法：</span>
                <select id="algoSelect"></select>
                <span class="algo-count" id="algoCount"></span>
            </div>
            <div style="font-size:12px;color:var(--text3);" id="dataStatus">等待数据...</div>
        </div>
    </div>

    <!-- 最新开奖 -->
    <div class="glass">
        <div class="glass-title"><span>📊 最新开奖</span><span id="latestPeriod" style="font-size:13px;color:var(--text2);">--</span></div>
        <div class="flex" style="justify-content:center;gap:10px;flex-wrap:wrap;">
            <div class="flex" id="latestBalls">
                <span class="ball ball-0">-</span>
                <span class="ball ball-0">-</span>
                <span class="ball ball-0">-</span>
            </div>
            <div style="font-size:16px;font-weight:700;color:var(--gold);" id="latestSum">--</div>
            <div id="latestTags"><span class="tag tag-small">小</span><span class="tag tag-even">双</span></div>
        </div>
        <div style="display:flex;justify-content:center;gap:16px;font-size:13px;color:var(--text3);margin-top:4px;">
            <span>⏳ 下期 <span id="countdownNext">--:--</span></span>
            <span class="countdown-timer" id="countdownTimer">--:--</span>
        </div>
        <div class="progress-bar"><div class="fill" id="progressFill" style="width:0%;"></div></div>
    </div>

    <!-- 手动输入 -->
    <div class="glass manual-panel" id="manualPanel">
        <div class="glass-title"><span>📝 手动输入</span></div>
        <div class="flex" style="justify-content:center;gap:6px;flex-wrap:wrap;">
            <div class="input-group">
                <label>最新一期</label>
                <input id="m1" type="number" min="0" max="9" placeholder="A" value="8">
                <input id="m2" type="number" min="0" max="9" placeholder="B" value="1">
                <input id="m3" type="number" min="0" max="9" placeholder="C" value="9">
            </div>
            <div class="input-group">
                <label>上一期</label>
                <input id="m4" type="number" min="0" max="9" placeholder="A" value="7">
                <input id="m5" type="number" min="0" max="9" placeholder="B" value="4">
                <input id="m6" type="number" min="0" max="9" placeholder="C" value="0">
            </div>
            <button class="btn btn-success btn-sm" id="manualCalcBtn">计算</button>
        </div>
        <div style="font-size:12px;color:var(--text3);margin-top:4px;">💡 接口失败时手动输入</div>
    </div>

    <!-- 预测结果 -->
    <div class="glass">
        <div class="glass-title"><span>🔮 预测结果</span><span id="resultAlgo" style="font-size:11px;color:var(--text3);">--</span></div>
        <div id="resultContent" class="result-box">
            <div class="big" id="resultMain">等待数据...</div>
            <div class="sub" id="resultSub"></div>
        </div>
        <div class="flex" style="margin-top:6px;">
            <button class="btn btn-sm" id="copyResultBtn">📋 复制</button>
            <span id="hitStatus" style="font-size:13px;color:var(--text3);margin-left:auto;"></span>
        </div>
    </div>

    <!-- 统计 -->
    <div class="glass">
        <div class="glass-title"><span>📈 统计</span></div>
        <div class="grid-4">
            <div class="stat-card"><div class="num" id="statTotal">0</div><div class="label">预测</div></div>
            <div class="stat-card"><div class="num" id="statHit">0</div><div class="label">命中</div></div>
            <div class="stat-card"><div class="num" id="statRate">0%</div><div class="label">命中率</div></div>
            <div class="stat-card"><div class="num" id="statStreak">0</div><div class="label">连胜</div></div>
        </div>
    </div>

    <!-- 历史 -->
    <div class="glass">
        <div class="glass-title"><span>📋 记录</span><button class="btn btn-sm btn-danger" id="clearHistoryBtn">清空</button></div>
        <div class="table-wrap">
            <table><thead><tr><th>期号</th><th>推荐</th><th>实际</th><th>结果</th></tr></thead>
                <tbody id="historyBody"><tr><td colspan="4" style="text-align:center;color:var(--text3);padding:16px 0;">暂无</td></tr></tbody>
            </table>
        </div>
    </div>

</div>

<script>
// ============================================================
// 120算法 · 简洁名称(无数学符号)
// ============================================================
function $(id){return document.getElementById(id);}
function showToast(msg,dur=1500){
    let el=$('toast');
    if(!el){el=document.createElement('div');el.id='toast';el.className='toast';document.body.appendChild(el);}
    el.textContent=msg;el.classList.add('show');
    clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),dur);
}
function getCombo(n){ let size = n >= 14 ? "大" : "小"; let parity = n % 2 === 0 ? "双" : "单"; return size + parity; }
function getBallColor(n){ if(n<=4)return 'ball-0'; if(n<=9)return 'ball-1'; if(n<=14)return 'ball-2'; if(n<=19)return 'ball-3'; return 'ball-4'; }

const API_URL = "https://pc28.help/api/kj.json?nbr=300";
const ALL_COMBOS = ["小单","小双","大单","大双"];
const DOUBLE_MAP = {0:['小双','大单'],1:['小单','大双'],2:['小双','大双'],3:['小单','大单']};
const OPPOSITE = {"小单":"大双","小双":"大单","大单":"小双","大双":"小单"};

// ---------- 动态背景 ----------
function initBg(){
    const canvas=document.getElementById('bgCanvas');
    const ctx=canvas.getContext('2d');
    let w,h; const particles=[]; const COUNT=120;
    function resize(){ w=canvas.width=window.innerWidth; h=canvas.height=window.innerHeight; }
    window.addEventListener('resize',resize); resize();
    class Particle{
        constructor(){ this.reset(); }
        reset(){ this.x=Math.random()*w; this.y=Math.random()*h; this.size=Math.random()*3+1.5; this.speedX=(Math.random()-0.5)*0.4; this.speedY=(Math.random()-0.5)*0.4; this.opacity=Math.random()*0.4+0.2; this.hue=Math.random()*60+30; this.pulse=Math.random()*Math.PI*2; }
        update(){ this.x+=this.speedX; this.y+=this.speedY; if(this.x<0||this.x>w)this.speedX*=-1; if(this.y<0||this.y>h)this.speedY*=-1; this.pulse+=0.02; }
        draw(){ let glow=Math.sin(this.pulse)*0.3+0.7; ctx.beginPath(); ctx.arc(this.x,this.y,this.size,0,Math.PI*2); ctx.fillStyle=`hsla(${this.hue},100%,70%,${this.opacity*glow})`; ctx.fill(); let grad=ctx.createRadialGradient(this.x,this.y,0,this.x,this.y,this.size*5); grad.addColorStop(0,`hsla(${this.hue},100%,70%,${0.1*glow})`); grad.addColorStop(1,`hsla(${this.hue},100%,70%,0)`); ctx.fillStyle=grad; ctx.beginPath(); ctx.arc(this.x,this.y,this.size*5,0,Math.PI*2); ctx.fill(); }
    }
    for(let i=0;i<COUNT;i++) particles.push(new Particle());
    function drawLines(){
        for(let i=0;i<particles.length;i++){ for(let j=i+1;j<particles.length;j++){ let dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y; let dist=Math.sqrt(dx*dx+dy*dy); if(dist<100){ ctx.beginPath(); ctx.moveTo(particles[i].x,particles[i].y); ctx.lineTo(particles[j].x,particles[j].y); let alpha=(1-dist/100)*0.12; ctx.strokeStyle=`rgba(255,215,0,${alpha})`; ctx.lineWidth=0.6; ctx.stroke(); } } }
    }
    function animate(){ ctx.clearRect(0,0,w,h); for(let p of particles){ p.update(); p.draw(); } drawLines(); requestAnimationFrame(animate); }
    animate();
}

// ---------- 120算法(纯净名称) ----------
function buildAlgorithms(){
    let algos = {};
    let id = 0;

    // 核心算法列表(用简洁中文名)
    const coreList = [
        { key: 'log10_kill', name: '对数杀组法', type: 'kill', calc: (d)=>{ let L=d[0].sum; let v=Math.log10(L+1)*((L%10)+1); let r=Math.floor(v)%4; let k={0:'小单',1:'小双',2:'大单',3:'大双'}[r]; return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)}; } },
        { key: 'sin_kill', name: '正弦杀组法', type: 'kill', calc: (d)=>{ let L=d[0].sum; let v=Math.abs(Math.sin(L+1))*((L%10)+1); let r=Math.floor(v)%4; let k={0:'小单',1:'小双',2:'大单',3:'大双'}[r]; return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)}; } },
        { key: 'cos_kill', name: '余弦杀组法', type: 'kill', calc: (d)=>{ let L=d[0].sum; let v=Math.abs(Math.cos(L+1))*((L%10)+1); let r=Math.floor(v)%4; let k={0:'小单',1:'小双',2:'大单',3:'大双'}[r]; return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)}; } },
        { key: 'tan_kill', name: '正切杀组法', type: 'kill', calc: (d)=>{ let L=d[0].sum; let v=Math.abs(Math.tan(L+1))*((L%10)+1); let r=Math.floor(v)%4; let k={0:'小单',1:'小双',2:'大单',3:'大双'}[r]; return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)}; } },
        { key: 'sqrt_kill', name: '开方杀组法', type: 'kill', calc: (d)=>{ let L=d[0].sum; let v=Math.sqrt(L+1)*((L%10)+1); let r=Math.floor(v)%4; let k={0:'小单',1:'小双',2:'大单',3:'大双'}[r]; return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)}; } },
        { key: 'cross_double', name: '上下球交叉法', type: 'double', calc: (d)=>{ let b1=d[0].balls,b2=d[1].balls; let a=b1[0]+b2[0],b=b1[1]+b2[1],c=b1[2]+b2[2]; let r1=getCombo(a),r2=getCombo(b),r3=getCombo(c); let cnt={小单:0,小双:0,大单:0,大双:0}; cnt[r1]++;cnt[r2]++;cnt[r3]++; let sorted=Object.entries(cnt).sort((x,y)=>y[1]-x[1]); return {type:'double', result: sorted.slice(0,2).map(x=>x[0])}; } },
        { key: 'sin_double', name: '正弦双组法', type: 'double', calc: (d)=>{ let L=d[0].sum; let v=Math.abs(Math.sin(L+1))*((L%10)+1); let r=Math.floor(v)%4; return {type:'double', result: DOUBLE_MAP[r]||['小单','大双']}; } },
        { key: 'mod7_double', name: '七余双组法', type: 'double', calc: (d)=>{ let r=d[0].sum%7; let map={0:['小单','小双'],1:['小单','小双'],2:['小双','大双'],3:['小双','大双'],4:['大单','大双'],5:['大单','大双'],6:['小单','大单']}; return {type:'double', result: map[r]||['小单','大双']}; } },
        { key: 'trend5_double', name: '五期趋势双组', type: 'double', calc: (d)=>{ if(d.length<5)return {type:'double',result:['小单','大双']}; let cnt={小单:0,小双:0,大单:0,大双:0}; for(let i=0;i<5;i++) cnt[d[i].combo]++; let max=Math.max(...Object.values(cnt)); let hot=Object.keys(cnt).filter(k=>cnt[k]===max); let kill=hot[0]||'小单'; let res=ALL_COMBOS.filter(c=>c!==kill).slice(0,2); if(res.length<2)res=['小单','大双']; return {type:'double', result: res}; } },
        { key: 'opposite_double', name: '对宫双组法', type: 'double', calc: (d)=>{ let combo=d[0].combo; let opp=OPPOSITE[combo]||'大双'; let res=[opp, ALL_COMBOS.find(c=>c!==opp&&c!==combo)||'小单']; return {type:'double', result: res.slice(0,2)}; } }
    ];

    for(let item of coreList){
        algos[item.key] = { name: item.name, type: item.type, calc: item.calc };
        id++;
    }

    // 变体算法(编号命名，不带数学符号)
    let counter = 1;
    const funcs = [
        { fn: Math.sin, abs: true, label: '正弦' },
        { fn: Math.cos, abs: true, label: '余弦' },
        { fn: Math.tan, abs: true, label: '正切' },
        { fn: Math.log10, abs: false, label: '对数' },
        { fn: Math.sqrt, abs: false, label: '开方' },
        { fn: Math.log, abs: false, label: '自然对数' }
    ];
    const divs = [3,4,5,6,7,8,9,10,13,17,21];
    const coeffs = [0.382,0.5,0.618,0.7,0.8,1.0,1.2,1.5,2.0,2.5,3.0];

    for(let f of funcs){
        for(let div of divs){
            for(let coeff of coeffs){
                if(counter > 110) break;
                let nameKill = `杀组法${counter}`;
                algos['kill_'+counter] = {
                    name: nameKill,
                    type: 'kill',
                    calc: (function(fn, abs, div, coeff){
                        return function(data){
                            let L=data[0].sum;
                            let v = fn(L+1);
                            if(abs) v = Math.abs(v);
                            let intPart = Math.floor(v * coeff) % div;
                            let k = {0:'小单',1:'小双',2:'大单',3:'大双'}[intPart % 4] || '小单';
                            return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)};
                        };
                    })(f.fn, f.abs, div, coeff)
                };
                counter++;
                if(counter > 110) break;
                let nameDouble = `双组法${counter}`;
                algos['double_'+counter] = {
                    name: nameDouble,
                    type: 'double',
                    calc: (function(fn, abs, div, coeff){
                        return function(data){
                            let L=data[0].sum;
                            let v = fn(L+1);
                            if(abs) v = Math.abs(v);
                            let intPart = Math.floor(v * coeff) % div;
                            return {type:'double', result: DOUBLE_MAP[intPart % 4] || ['小单','大双']};
                        };
                    })(f.fn, f.abs, div, coeff)
                };
                counter++;
            }
            if(counter > 110) break;
        }
        if(counter > 110) break;
    }

    // 球位置算法
    const posMap = {A:0, B:1, C:2};
    for(let p of ['A','B','C']){
        for(let div of [3,4,5,6,7,8,9,10]){
            for(let coeff of [0.5,0.618,0.7,1.0,1.5]){
                if(counter > 120) break;
                let idx = posMap[p];
                let nameKill = `球杀法${counter}`;
                algos['kill_'+counter] = {
                    name: nameKill,
                    type: 'kill',
                    calc: (function(idx, div, coeff){
                        return function(data){
                            let b = data[0].balls[idx];
                            let intPart = Math.floor(b * coeff) % div;
                            let k = {0:'小单',1:'小双',2:'大单',3:'大双'}[intPart % 4] || '小单';
                            return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)};
                        };
                    })(idx, div, coeff)
                };
                counter++;
                if(counter > 120) break;
                let nameDouble = `球双法${counter}`;
                algos['double_'+counter] = {
                    name: nameDouble,
                    type: 'double',
                    calc: (function(idx, div, coeff){
                        return function(data){
                            let b = data[0].balls[idx];
                            let intPart = Math.floor(b * coeff) % div;
                            return {type:'double', result: DOUBLE_MAP[intPart % 4] || ['小单','大双']};
                        };
                    })(idx, div, coeff)
                };
                counter++;
            }
            if(counter > 120) break;
        }
        if(counter > 120) break;
    }

    // 尾数算法
    for(let div of [3,4,5,6,7,8,9,10]){
        if(counter > 120) break;
        let nameKill = `尾杀法${counter}`;
        algos['kill_'+counter] = {
            name: nameKill,
            type: 'kill',
            calc: (function(div){
                return function(data){
                    let L = data[0].sum;
                    let intPart = (L % 10) % div;
                    let k = {0:'小单',1:'小双',2:'大单',3:'大双'}[intPart % 4] || '小单';
                    return {type:'kill', kill:k, recommend: ALL_COMBOS.filter(c=>c!==k)};
                };
            })(div)
        };
        counter++;
        if(counter > 120) break;
        let nameDouble = `尾双法${counter}`;
        algos['double_'+counter] = {
            name: nameDouble,
            type: 'double',
            calc: (function(div){
                return function(data){
                    let L = data[0].sum;
                    let intPart = (L % 10) % div;
                    return {type:'double', result: DOUBLE_MAP[intPart % 4] || ['小单','大双']};
                };
            })(div)
        };
        counter++;
    }

    console.log('✅ 总算法数:', Object.keys(algos).length);
    return algos;
}

const ALGOS = buildAlgorithms();
const ALGO_KEYS = Object.keys(ALGOS);

// ---------- 状态 ----------
let dataList = [];
let history = [];
let lastResult = null;
let lastPeriod = null;
let autoTimer = 30;
let autoInterval = null;

// ---------- 数据获取 ----------
async function fetchData(){
    try{
        let resp = await fetch(API_URL);
        if(!resp.ok) throw new Error('HTTP '+resp.status);
        let raw = await resp.json();
        return raw;
    }catch(e){ console.warn('API请求失败:', e.message); return null; }
}

function parseData(raw){
    if(!raw) return null;
    let items = [];
    if(raw.data && Array.isArray(raw.data)){
        for(let item of raw.data){
            let numStr = item.number || '';
            if(numStr){
                let balls = numStr.split('+').map(Number);
                if(balls.length===3){
                    items.push({
                        period: item.nbr || '未知',
                        balls: balls,
                        sum: parseInt(item.num) || balls.reduce((a,b)=>a+b,0),
                        combo: item.combination || getCombo(balls.reduce((a,b)=>a+b,0))
                    });
                }
            }
        }
    }
    if(items.length===0) return null;
    items.sort((a,b)=>parseInt(b.period)-parseInt(a.period));
    return items;
}

// ---------- 手动计算 ----------
function manualCalculate(){
    let n1=parseInt($('m1').value)||0, n2=parseInt($('m2').value)||0, n3=parseInt($('m3').value)||0;
    let m1=parseInt($('m4').value)||0, m2=parseInt($('m5').value)||0, m3=parseInt($('m6').value)||0;
    let data = [
        { balls:[n1,n2,n3], sum:n1+n2+n3, combo:getCombo(n1+n2+n3) },
        { balls:[m1,m2,m3], sum:m1+m2+m3, combo:getCombo(m1+m2+m3) }
    ];
    dataList = data;
    renderLatest(data[0]);
    let algoKey = $('algoSelect').value;
    let algo = ALGOS[algoKey];
    if(!algo){ showToast('算法未找到'); return; }
    let result = algo.calc(data);
    lastResult = result;
    renderRecommendation(result, algoKey);
    let period = '手动';
    let prevActual = data[1]?.combo;
    if(prevActual){
        let isHit = false;
        if(result.kill){ isHit = result.kill !== prevActual; }
        else { isHit = result.result.includes(prevActual); }
        addHistory(period, result, prevActual, isHit);
    }
    $('hitStatus').textContent = '✅ 手动计算完成';
}

// ---------- 渲染 ----------
function renderLatest(item){
    if(!item){
        $('latestPeriod').textContent='--';
        $('latestBalls').innerHTML='<span class="ball ball-0">-</span><span class="ball ball-0">-</span><span class="ball ball-0">-</span>';
        $('latestSum').textContent='--';
        $('latestTags').innerHTML='<span class="tag tag-small">小</span><span class="tag tag-even">双</span>';
        return;
    }
    $('latestPeriod').textContent=item.period;
    $('latestBalls').innerHTML=item.balls.map((v,i)=>`<span class="ball ${getBallColor(v)}">${v}</span>`).join('');
    $('latestSum').textContent=item.sum;
    let size=item.sum>=14?'大':'小', parity=item.sum%2===0?'双':'单';
    $('latestTags').innerHTML=`<span class="tag ${size==='大'?'tag-big':'tag-small'}">${size}</span><span class="tag ${parity==='单'?'tag-odd':'tag-even'}">${parity}</span>`;
}

function renderRecommendation(result, algoKey){
    let algo = ALGOS[algoKey];
    if(!result){$('resultMain').textContent='等待数据...';$('resultSub').textContent='';return;}
    $('resultAlgo').textContent = algo.name;
    if(result.type==='kill'){
        $('resultMain').innerHTML = `🔴 杀：<span class="kill">${result.kill}</span>`;
        $('resultSub').innerHTML = `✅ 买：<span class="buy">${result.recommend.join('、')}</span>`;
    } else {
        $('resultMain').innerHTML = `🟢 推荐：<span class="buy">${result.result.join(' + ')}</span>`;
        $('resultSub').innerHTML = `📌 杀：${ALL_COMBOS.filter(c=>!result.result.includes(c)).join('、')}`;
    }
}

function updateStats(){
    $('statTotal').textContent = history.length;
    let hitCount = history.filter(h=>h.hit).length;
    $('statHit').textContent = hitCount;
    $('statRate').textContent = history.length ? Math.round(hitCount/history.length*100)+'%' : '0%';
    let streak=0;
    for(let i=history.length-1; i>=0; i--){ if(history[i].hit) streak++; else break; }
    $('statStreak').textContent = streak;
    renderHistory();
}

function renderHistory(){
    let tbody = $('historyBody');
    if(!history.length){tbody.innerHTML='<tr><td colspan="4" style="text-align:center;color:var(--text3);padding:16px 0;">暂无</td></tr>';return;}
    let html='';
    let show = history.slice(-20).reverse();
    for(let h of show){
        let status = h.hit ? '<span class="status-badge hit">🀄️</span>' : '<span class="status-badge miss">🍉</span>';
        let detail = h.kill ? `杀${h.kill}` : h.result.join('+');
        html+=`<tr><td>${h.period||'--'}</td><td>${detail}</td><td>${h.actual||'--'}</td><td>${status}</td></tr>`;
    }
    tbody.innerHTML=html;
}

function addHistory(period, result, actual, hit){
    history.push({period, result: result.result || [result.kill], kill: result.kill, actual, hit});
    if(history.length>200) history.shift();
    updateStats();
    $('hitStatus').textContent = hit ? '🀄️' : '🍉';
}

// ---------- 主刷新 ----------
async function refreshData(){
    $('dataStatus').textContent = '⏳ 加载...';
    $('resultMain').textContent = '加载中...';
    let raw = await fetchData();
    if(!raw){
        $('dataStatus').textContent = '⚠️ API失败，手动输入';
        $('manualPanel').style.display = 'block';
        if(!dataList || dataList.length<2){
            $('resultMain').textContent = '请手动输入号码';
            $('resultSub').textContent = '点击「计算」';
        }
        return;
    }
    $('manualPanel').style.display = 'none';
    let parsed = parseData(raw);
    if(!parsed || parsed.length<2){
        $('dataStatus').textContent = '⚠️ 数据不足';
        return;
    }
    dataList = parsed;
    $('dataStatus').textContent = `✅ ${dataList.length}期`;
    renderLatest(dataList[0]);
    updateCountdown();
    let algoKey = $('algoSelect').value;
    let algo = ALGOS[algoKey];
    if(!algo){ showToast('算法未找到'); return; }
    let result = algo.calc(dataList);
    lastResult = result;
    renderRecommendation(result, algoKey);
    if(history.length>0 && lastPeriod){
        let last = history[history.length-1];
        let prevActual = dataList[1]?.combo;
        if(prevActual && last.period === dataList[1]?.period){
            let isHit = false;
            if(last.kill){ isHit = last.kill !== prevActual; }
            else { isHit = last.result.includes(prevActual); }
            if(!last.hitChecked){ last.hit=isHit; last.hitChecked=true; addHistory(last.period, last, prevActual, isHit); }
        }
    }
    lastPeriod = dataList[0].period;
    autoTimer = 30;
}

// ---------- 倒计时 ----------
function updateCountdown(){
    let now = new Date();
    let next = new Date(now);
    next.setMinutes(next.getMinutes() + 3);
    next.setSeconds(0);
    let diff = Math.floor((next-now)/1000);
    if(diff<0) diff=0;
    let mins = String(Math.floor(diff/60)).padStart(2,'0');
    let secs = String(diff%60).padStart(2,'0');
    $('countdownTimer').textContent = mins+':'+secs;
    $('countdownNext').textContent = next.toLocaleTimeString();
    let total = 180;
    let pct = ((total-diff)/total*100);
    $('progressFill').style.width = Math.min(100,pct)+'%';
    setTimeout(updateCountdown, 1000);
}

// ---------- 自动刷新 ----------
function startAuto(){
    if(autoInterval) clearInterval(autoInterval);
    autoTimer=30;
    $('autoStatus').textContent = '▶️ 30s';
    autoInterval = setInterval(()=>{
        autoTimer--;
        $('autoStatus').textContent = '▶️ '+autoTimer+'s';
        if(autoTimer<=0){ autoTimer=30; if(!document.hidden) refreshData(); }
    }, 1000);
}

function toggleAuto(){
    if(autoInterval){ clearInterval(autoInterval); autoInterval=null; $('autoStatus').textContent='⏸️ 暂停'; }
    else { startAuto(); }
}

function changeAlgo(){
    let algoKey = $('algoSelect').value;
    let algo = ALGOS[algoKey];
    if(!algo) return;
    if(dataList && dataList.length>=2){
        let result = algo.calc(dataList);
        lastResult = result;
        renderRecommendation(result, algoKey);
    }
}

// ---------- 初始化下拉 ----------
function initSelect(){
    let select = $('algoSelect');
    select.innerHTML = '';
    let coreKeys = ['log10_kill','sin_kill','cos_kill','tan_kill','sqrt_kill','cross_double','sin_double','mod7_double','trend5_double','opposite_double'];
    let otherKeys = ALGO_KEYS.filter(k=>!coreKeys.includes(k));
    let sorted = coreKeys.concat(otherKeys.sort());
    for(let key of sorted){
        let opt = document.createElement('option');
        opt.value = key;
        opt.textContent = ALGOS[key].name;
        select.appendChild(opt);
    }
    $('algoCount').textContent = `(${sorted.length}个算法)`;
}

// ---------- 事件 ----------
function bindEvents(){
    $('themeToggle').addEventListener('click', ()=>{
        let theme = document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark';
        document.documentElement.setAttribute('data-theme',theme);
        localStorage.setItem('pc28_theme',theme);
        $('themeToggle').textContent=theme==='dark'?'🌓':'☀️';
    });
    $('algoSelect').addEventListener('change', changeAlgo);
    $('refreshBtn').addEventListener('click', refreshData);
    $('copyResultBtn').addEventListener('click', ()=>{
        let main = $('resultMain').textContent;
        let sub = $('resultSub').textContent;
        let text = main + ' ' + sub;
        if(navigator.clipboard){ navigator.clipboard.writeText(text).then(()=>showToast('已复制')); }
        else{ showToast('复制失败'); }
    });
    $('clearHistoryBtn').addEventListener('click', ()=>{ if(confirm('清空所有记录？')){ history=[]; updateStats(); showToast('已清空'); } });
    $('manualCalcBtn').addEventListener('click', manualCalculate);
    $('autoStatus').addEventListener('click', toggleAuto);
}

// ---------- 启动 ----------
function init(){
    let theme = localStorage.getItem('pc28_theme')||'dark';
    document.documentElement.setAttribute('data-theme',theme);
    $('themeToggle').textContent=theme==='dark'?'🌓':'☀️';
    $('headerTime').textContent = new Date().toLocaleTimeString();
    initBg();
    initSelect();
    bindEvents();
    refreshData();
    startAuto();
    setInterval(()=>$('headerTime').textContent=new Date().toLocaleTimeString(),30000);
    console.log('🚀 PC28 算法库已启动');
}
document.addEventListener('DOMContentLoaded', init);
</script>
