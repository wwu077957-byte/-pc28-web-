<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>多情PC28 · 液态预测</title>
    <!-- Chart.js 用于图表 -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- html2canvas 用于截图分享 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        /* ===== CSS变量（主题色、深浅模式） ===== */
        :root {
            --bg: #0b0b0f;
            --card-bg: rgba(20, 20, 40, 0.55);
            --card-border: rgba(255, 255, 255, 0.12);
            --text-primary: #f0f0f5;
            --text-secondary: #b0b0c0;
            --text-muted: #7a7a8a;
            --shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
            --input-bg: rgba(255, 255, 255, 0.06);
            --result-bg: rgba(255, 255, 255, 0.05);
            --badge-bg: rgba(247, 151, 30, 0.2);
            --badge-color: #f7971e;
            --gradient-primary: linear-gradient(135deg, #f7971e, #ffd200);
            --gradient-pc28: linear-gradient(135deg, #f6d365, #fda085);
            --gradient-tg: linear-gradient(135deg, #4facfe, #00f2fe);
            --scrollbar-thumb: rgba(247, 151, 30, 0.3);
            --border-color: rgba(255, 255, 255, 0.08);
            --theme-color: #f7971e;
            --glass-bg: rgba(255, 255, 255, 0.04);
            --glass-shine: rgba(255, 255, 255, 0.06);
        }
        /* 深色模式已固定（因为液态玻璃在深色背景下更炫），但保留切换变量 */
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            overflow-x: hidden;
            position: relative;
        }
        /* ===== 液态玻璃背景（动态流动光泽） ===== */
        body::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 40%, rgba(247, 151, 30, 0.15), transparent 60%),
                        radial-gradient(circle at 70% 80%, rgba(255, 210, 0, 0.10), transparent 50%),
                        radial-gradient(circle at 20% 70%, rgba(100, 200, 255, 0.08), transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(200, 100, 255, 0.08), transparent 50%);
            background-size: 100% 100%;
            animation: liquidGlass 20s ease-in-out infinite alternate;
            pointer-events: none;
            z-index: 0;
        }
        @keyframes liquidGlass {
            0% { transform: translate(0, 0) scale(1) rotate(0deg); }
            25% { transform: translate(5%, -5%) scale(1.05) rotate(2deg); }
            50% { transform: translate(-3%, 8%) scale(0.95) rotate(-3deg); }
            75% { transform: translate(8%, 3%) scale(1.02) rotate(1deg); }
            100% { transform: translate(-5%, -3%) scale(0.98) rotate(-1deg); }
        }
        /* 增加玻璃光泽条纹 */
        body::after {
            content: '';
            position: fixed;
            top: -20%;
            left: -20%;
            width: 140%;
            height: 140%;
            background: repeating-linear-gradient(45deg,
                transparent 0px,
                transparent 40px,
                rgba(255,255,255,0.02) 40px,
                rgba(255,255,255,0.02) 42px,
                transparent 42px,
                transparent 80px);
            animation: shineMove 12s linear infinite;
            pointer-events: none;
            z-index: 0;
        }
        @keyframes shineMove {
            0% { transform: translateX(-100%) rotate(45deg); }
            100% { transform: translateX(100%) rotate(45deg); }
        }

        /* 雪花 Canvas 覆盖层 */
        #snowCanvas {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 9999;
        }

        .container {
            max-width: 1000px;
            width: 100%;
            position: relative;
            z-index: 1;
            padding-bottom: 40px;
        }

        /* 玻璃卡片（毛玻璃+光泽） */
        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-radius: 40px;
            padding: 24px 28px;
            margin-bottom: 24px;
            border: 1px solid var(--card-border);
            box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }
        /* 卡片内部光泽 */
        .glass-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.05), transparent 70%);
            pointer-events: none;
        }
        .glass-card:active { transform: scale(0.98); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }

        /* 通用组件 */
        .flex-between { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .flex-center { display: flex; align-items: center; gap: 8px; }
        .btn {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: white;
            padding: 10px 22px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(.34,1.56,.64,1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            backdrop-filter: blur(8px);
            text-decoration: none;
        }
        .btn:active { transform: scale(0.94); }
        .btn-primary { background: var(--gradient-primary); border: none; color: #0b0b0f; box-shadow: 0 8px 24px rgba(247,151,30,0.3); }
        .btn-pc28 { background: var(--gradient-pc28); border: none; color: #0b0b0f; box-shadow: 0 8px 24px rgba(253,160,133,0.3); }
        .btn-tg { background: var(--gradient-tg); border: none; color: white; }
        .btn-theme { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); font-size: 18px; padding: 8px 16px; }
        .input-field {
            width: 100%;
            padding: 14px 20px;
            border-radius: 40px;
            border: 1px solid var(--card-border);
            background: var(--input-bg);
            color: var(--text-primary);
            font-size: 15px;
            outline: none;
            transition: all 0.3s;
            margin-bottom: 14px;
            font-weight: 500;
        }
        .input-field::placeholder { color: var(--text-muted); }
        .input-field:focus { border-color: #f7971e; box-shadow: 0 0 0 4px rgba(247,151,30,0.15); background: rgba(255,255,255,0.08); }
        .badge {
            display: inline-block;
            background: var(--badge-bg);
            padding: 4px 16px;
            border-radius: 30px;
            font-size: 12px;
            color: var(--badge-color);
            font-weight: 600;
            backdrop-filter: blur(4px);
        }
        .section-title {
            font-weight: 700;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            color: var(--text-primary);
        }
        .row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid var(--border-color);
        }
        .row:last-child { border-bottom: none; }
        .label { color: var(--text-secondary); }
        .value { font-weight: 600; }
        .rec-card {
            background: rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 12px 16px;
            margin: 6px 0;
            text-align: center;
            font-size: 20px;
            font-weight: 700;
            border-left: 4px solid var(--theme-color);
        }
        .rec-main { border-left-color: #ffd700; background: rgba(255,215,0,0.08); }
        .chart-box { background: rgba(0,0,0,0.3); border-radius: 14px; padding: 12px; margin: 10px 0; }
        .chart-container { position: relative; height: 200px; }
        .chart-container canvas { width: 100% !important; height: 100% !important; }
        .status-line {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 14px;
            gap: 6px;
        }
        .status-line span {
            background: rgba(255,255,255,0.05);
            padding: 4px 16px;
            border-radius: 30px;
            backdrop-filter: blur(4px);
        }
        .time-display { font-weight: 600; color: var(--badge-color); }
        .countdown-big {
            font-size: 18px;
            font-weight: 700;
            color: var(--badge-color);
            background: rgba(247,151,30,0.15);
            padding: 4px 16px;
            border-radius: 40px;
            display: inline-block;
        }
        .hot-cold-list { display: flex; flex-wrap: wrap; gap: 6px 16px; padding: 4px 0; }
        .hot { color: #ff4757; font-weight: 700; }
        .cold { color: #1e90ff; font-weight: 700; }
        .footer { text-align: center; color: var(--text-muted); font-size: 12px; padding: 20px 0 10px; opacity: 0.7; }
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.1);
            border-top-color: #f7971e;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* 网格布局 */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        @media (max-width:600px) {
            body { padding: 12px; }
            .glass-card { padding: 18px 20px; border-radius: 32px; }
            .grid-2 { grid-template-columns: 1fr; }
            .btn { font-size: 13px; padding: 8px 16px; }
            .input-field { font-size: 14px; padding: 12px 16px; }
            .status-line { font-size: 12px; }
            .rec-card { font-size: 17px; }
            .countdown-big { font-size: 16px; padding: 2px 12px; }
        }

        /* 额外工具 */
        .param-slider { width: 100%; accent-color: var(--theme-color); }
        .param-label { display: flex; justify-content: space-between; font-size: 14px; }
        .btn-small { font-size: 10px; padding: 2px 8px; }
        .theme-selector { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
        .theme-dot {
            width: 24px; height: 24px; border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.2);
            cursor: pointer; transition: all 0.2s;
        }
        .theme-dot:hover { transform: scale(1.2); }
        .theme-dot.active { border-color: #fff; box-shadow: 0 0 12px var(--theme-color); }
        .history-table { width: 100%; font-size: 13px; border-collapse: collapse; margin-top: 8px; }
        .history-table th, .history-table td { padding: 6px 4px; border-bottom: 1px solid var(--border-color); text-align: center; }
        .history-table .hit { color: #2ed573; }
        .history-table .miss { color: #ff4757; }
        .share-btn { background: var(--gradient-tg); border: none; color: white; }
    </style>
</head>
<body>

    <!-- 雪花 Canvas -->
    <canvas id="snowCanvas"></canvas>

    <div class="container">

        <!-- ===== 顶部 ===== -->
        <div class="glass-card">
            <div class="flex-between">
                <div>
                    <div class="section-title" style="font-size:28px; margin-bottom:0;">🍮 多情PC28</div>
                    <div style="font-size:14px; color:var(--text-secondary); margin-top:2px;">液态预测 · 智能分析</div>
                </div>
                <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                    <span class="badge" id="statusBadge">● 在线</span>
                    <button class="btn btn-theme" onclick="toggleTheme()" title="切换主题">🌓</button>
                    <div class="theme-selector" id="themeSelector"></div>
                </div>
            </div>
            <div class="flex-between" style="margin-top:12px;">
                <div class="flex-center" style="gap:8px; flex-wrap:wrap;">
                    <a class="btn btn-tg" href="tg://resolve?domain=on9vv" target="_blank">📱 客服</a>
                    <button class="btn btn-pc28" onclick="fetchData()">🔄 获取数据</button>
                    <button class="btn btn-primary" onclick="manualRefresh()">🔍 手动预测</button>
                </div>
                <div class="flex-center">
                    <span style="font-size:13px; color:var(--text-secondary);">自动刷新</span>
                    <label class="switch">
                        <input type="checkbox" id="autoRefreshToggle" checked onchange="toggleAutoRefresh()">
                        <span class="slider"></span>
                    </label>
                </div>
            </div>
            <div class="status-line">
                <span>🕐 <span id="currentTime" class="time-display">--</span></span>
                <span>📍 <span id="userCity" class="time-display">获取中...</span></span>
                <span>🌐 <span id="ipLocation" class="time-display">获取中...</span></span>
                <span>⏳ 下次刷新：<span id="countdownDisplay" class="time-display">60秒</span></span>
                <span>⏱️ 距开奖：<span id="nextDrawCountdown" class="countdown-big">--</span></span>
            </div>
        </div>

        <!-- ===== PC28 预测核心 ===== -->
        <div class="glass-card">
            <div class="section-title">🎯 PC28 加拿大预测</div>
            <div class="flex-between" style="margin-bottom:12px;">
                <div class="flex-center">
                    <span style="font-size:14px; color:var(--text-secondary);">算法：</span>
                    <select id="algoSelect" style="background:var(--input-bg); border:1px solid var(--card-border); border-radius:30px; color:var(--text-primary); padding:8px 16px; font-size:14px; outline:none;">
                        <option value="three_step">三步算法</option>
                        <option value="wma">移动平均 (20期)</option>
                        <option value="markov">马尔可夫链</option>
                        <option value="ensemble">综合投票</option>
                    </select>
                </div>
                <span style="font-size:13px; color:var(--text-secondary);" id="dataCount">数据期数：0</span>
            </div>
            <!-- 参数调节 -->
            <div class="flex-between" style="margin:8px 0; padding:8px 0; border-top:1px solid var(--border-color); border-bottom:1px solid var(--border-color);">
                <div style="flex:1; margin-right:12px;">
                    <span class="param-label">WMA窗口期：<span id="wmaWindowDisplay">20</span></span>
                    <input type="range" id="wmaWindowSlider" class="param-slider" min="5" max="30" value="20" step="5">
                </div>
                <div style="flex:1;">
                    <span class="param-label">马尔可夫阶数：<span id="markovOrderDisplay">1</span></span>
                    <input type="range" id="markovOrderSlider" class="param-slider" min="1" max="2" value="1" step="1">
                </div>
            </div>
            <div id="resultArea"><div style="color:var(--text-muted);">点击 "获取数据" 开始</div></div>
            <!-- 图表 -->
            <div style="margin-top:16px;">
                <div style="font-weight:600; margin-bottom:8px;">📊 走势图与热力分布</div>
                <div class="chart-box">
                    <div class="chart-container"><canvas id="trendChart"></canvas></div>
                    <div style="font-size:12px; color:var(--text-secondary); text-align:center; margin-top:4px;">—— 红色虚线为预测趋势 ——</div>
                </div>
                <div class="chart-box">
                    <div class="chart-container"><canvas id="heatmapChart"></canvas></div>
                    <div style="font-size:12px; color:var(--text-secondary); text-align:center; margin-top:4px;">号码出现频率</div>
                </div>
            </div>
            <!-- 冷热 & 连出 -->
            <div style="margin-top:16px; display:flex; flex-wrap:wrap; gap:20px; background:var(--result-bg); border-radius:24px; padding:16px;">
                <div style="flex:1; min-width:150px;">
                    <div style="font-weight:600; font-size:15px;">🔥 热门号码</div>
                    <div id="hotNumbers" class="hot-cold-list">--</div>
                </div>
                <div style="flex:1; min-width:150px;">
                    <div style="font-weight:600; font-size:15px;">❄️ 冷门号码</div>
                    <div id="coldNumbers" class="hot-cold-list">--</div>
                </div>
                <div style="flex:1; min-width:150px;">
                    <div style="font-weight:600; font-size:15px;">📌 形态连出</div>
                    <div id="consecutiveStats" style="font-size:14px; color:var(--text-secondary);">--</div>
                </div>
            </div>
        </div>

        <!-- ===== 胜率统计 + 历史记录 ===== -->
        <div class="glass-card">
            <div class="section-title">🏆 预测胜率统计</div>
            <div class="flex-between">
                <span>算法胜率：<strong id="algoWinRate" style="color:var(--theme-color);">--%</strong></span>
                <span>用户胜率：<strong id="userWinRate" style="color:var(--theme-color);">--%</strong></span>
                <button class="btn btn-primary" onclick="resetHistory()" style="font-size:12px; padding:4px 12px;">重置记录</button>
            </div>
            <div style="margin-top:12px;">
                <div style="font-weight:600; font-size:15px;">📋 预测历史（最近10条）</div>
                <div id="historyContainer" style="max-height:200px; overflow-y:auto;">
                    <table class="history-table">
                        <thead><tr><th>时间</th><th>预测形态</th><th>开奖结果</th><th>状态</th><th>操作</th></tr></thead>
                        <tbody id="historyBody"><tr><td colspan="5" style="color:var(--text-muted);">暂无记录</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===== 遗漏走势图 ===== -->
        <div class="glass-card">
            <div class="section-title">📈 形态遗漏走势</div>
            <div class="chart-container" style="height:180px;"><canvas id="missTrendChart"></canvas></div>
        </div>

        <!-- ===== 和值分布 + 奇偶大小 ===== -->
        <div class="grid-2">
            <div class="glass-card">
                <div class="section-title" style="font-size:16px;">📊 和值分布</div>
                <div class="chart-container" style="height:150px;"><canvas id="sumDistChart"></canvas></div>
            </div>
            <div class="glass-card">
                <div class="section-title" style="font-size:16px;">📊 奇偶/大小比例</div>
                <div class="chart-container" style="height:150px;"><canvas id="ratioChart"></canvas></div>
            </div>
        </div>

        <!-- ===== 详细走势表格 ===== -->
        <div class="glass-card">
            <div class="section-title">📋 近期详细走势</div>
            <div id="detailTableContainer" style="max-height:200px; overflow-y:auto; font-size:13px;">
                <table class="history-table">
                    <thead><tr><th>期号</th><th>和值</th><th>大小</th><th>单双</th><th>拆分</th></tr></thead>
                    <tbody id="detailBody"><tr><td colspan="5" style="color:var(--text-muted);">暂无数据</td></tr></tbody>
                </table>
            </div>
        </div>

        <!-- ===== 形态转换提示 + 投注建议 ===== -->
        <div class="grid-2">
            <div class="glass-card">
                <div class="section-title">🔄 形态转换提示</div>
                <div id="transitionTip" style="font-size:16px; color:var(--text-secondary);">--</div>
            </div>
            <div class="glass-card" style="border-left:4px solid var(--theme-color);">
                <div class="section-title">💡 投注建议</div>
                <div id="betSuggestion" style="font-size:15px; display:flex; flex-wrap:wrap; gap:8px;">
                    <span>⭐ 主推：<strong style="color:var(--theme-color);">--</strong></span>
                    <span>🔹 次推：<strong style="color:var(--theme-color);">--</strong></span>
                    <span>🛡 补防：<strong style="color:var(--theme-color);">--</strong></span>
                    <span>❌ 杀号：<strong style="color:#ff4757;">--</strong></span>
                </div>
            </div>
        </div>

        <!-- ===== 网速 + 汇率 ===== -->
        <div class="grid-2">
            <div class="glass-card">
                <div class="section-title" style="font-size:16px;">📶 网速测试</div>
                <div id="speedResult" style="display:flex; justify-content:space-around; text-align:center; padding:10px 0;">
                    <div><div class="num" id="downloadSpeed" style="font-size:24px; font-weight:700; color:var(--badge-color);">--</div><div class="unit" style="font-size:14px; color:var(--text-muted);">下载 (Mbps)</div></div>
                    <div><div class="num" id="uploadSpeed" style="font-size:24px; font-weight:700; color:var(--badge-color);">--</div><div class="unit" style="font-size:14px; color:var(--text-muted);">上传 (Mbps)</div></div>
                </div>
                <button class="btn btn-pc28" onclick="testSpeed()" style="width:100%; justify-content:center;">🚀 测速</button>
                <div style="font-size:12px; color:var(--text-muted); text-align:center; margin-top:6px;" id="speedStatus">点击测速</div>
            </div>
            <div class="glass-card">
                <div class="section-title" style="font-size:16px;">💱 汇率换算</div>
                <div style="display:flex; flex-direction:column; gap:10px;">
                    <select id="currencyFrom" class="input-field" style="padding:10px 16px; margin:0;">
                        <option value="USDT">USDT</option>
                        <option value="TON">TON</option>
                        <option value="BTC">比特币</option>
                        <option value="ETH">以太坊</option>
                        <option value="USD">美元</option>
                        <option value="EUR">欧元</option>
                    </select>
                    <div style="display:flex; gap:10px;">
                        <input type="number" id="currencyAmount" class="input-field" value="1" style="flex:2; padding:10px 16px; margin:0;">
                        <button class="btn btn-primary" onclick="convertCurrency()" style="flex:1; justify-content:center;">换算</button>
                    </div>
                    <div style="font-size:20px; font-weight:700; color:var(--badge-color); text-align:center;" id="currencyResult">-- 人民币</div>
                </div>
            </div>
        </div>

        <!-- ===== USDT + TON ===== -->
