    <script>
        // ============================================================
        // 1. 雪花特效（大雪花）
        // ============================================================
        (function() {
            const canvas = document.getElementById('snowCanvas');
            const ctx = canvas.getContext('2d');
            let w, h, flakes = [];
            const MAX = 60;

            function resize() {
                w = window.innerWidth;
                h = window.innerHeight;
                canvas.width = w;
                canvas.height = h;
            }
            window.addEventListener('resize', resize);
            resize();

            class Flake {
                constructor() { this.reset(); }
                reset() {
                    this.x = Math.random() * w;
                    this.y = Math.random() * h - h;
                    this.r = Math.random() * 6 + 4; // 大雪花 4~10px
                    this.sy = Math.random() * 1.0 + 0.4;
                    this.sx = (Math.random() - 0.5) * 0.3;
                    this.o = Math.random() * 0.7 + 0.3;
                    this.phase = Math.random() * Math.PI * 2;
                }
                update() {
                    this.y += this.sy;
                    this.x += this.sx + Math.sin(this.phase) * 0.2;
                    this.phase += 0.02;
                    if (this.y > h + 30) { this.reset(); this.y = -10; }
                    if (this.x < -30) this.x = w + 30;
                    if (this.x > w + 30) this.x = -30;
                }
                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${this.o})`;
                    ctx.fill();
                    // 六角星效果（简单十字线）
                    ctx.strokeStyle = `rgba(255,255,255,${this.o*0.3})`;
                    ctx.lineWidth = 1;
                    for (let i=0; i<6; i++) {
                        let angle = i * Math.PI/3 + this.phase;
                        ctx.beginPath();
                        ctx.moveTo(this.x, this.y);
                        ctx.lineTo(this.x + Math.cos(angle)*this.r*0.8, this.y + Math.sin(angle)*this.r*0.8);
                        ctx.stroke();
                    }
                }
            }
            for (let i=0; i<MAX; i++) flakes.push(new Flake());
            function animate() {
                ctx.clearRect(0, 0, w, h);
                flakes.forEach(f => { f.update(); f.draw(); });
                requestAnimationFrame(animate);
            }
            animate();
        })();

        // ============================================================
        // 2. 主题切换 + 自定义色块
        // ============================================================
        const themes = [
            { name:'金', color:'#f7971e', value:'' },
