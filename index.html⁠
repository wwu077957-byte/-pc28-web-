        // ============================================================
        // 4. PC28 核心逻辑（完整）
        // ============================================================
        let pc28Records = [];
        let trendChartInstance = null, heatmapChartInstance = null, missTrendChartInstance = null, sumDistChartInstance = null, ratioChartInstance = null;
        let predictionHistory = JSON.parse(localStorage.getItem('predictionHistory')) || [];

        function generateThreeDigits(total) {
            for (let i = 0; i < 100; i++) { let a = Math.floor(Math.random() * 10), b = Math.floor(Math.random() * 10), c = Math.floor(Math.random() * 10); if (a + b + c === total) return [a, b, c]; }
            let a = Math.min(9, total), b = Math.min(9, total - a), c = total - a - b;
            if (c > 9) { c = 9; a = total - b - c; if (a < 0) a = 0; }
            return [a, b, c];
        }

        function classifyRecord(r) {
            let num = r.num, digits = generateThreeDigits(num);
            let size = num >= 14 ? "大" : "小", parity = num % 2 === 1 ? "单" : "双";
            return { expect: r.expect, num, digits, size, parity, form: size + parity };
        }

        function getWMAParams() { return parseInt(document.getElementById('wmaWindowSlider').value); }
        function getMarkovOrder() { return parseInt(document.getElementById('markovOrderSlider').value); }

        function algoThreeStep(records) {
            if (records.length < 3) return null;
            let n1 = records[0], n2 = records[1], n3 = records[2];
            let X = Math.floor(n1.num / 10), Y = n2.digits[0] || 0, Z = n3.digits[2] || 0;
            let mid = X + Y + Z, predVal = mid + n1.num;
            let size = predVal >= 14 ? "大" : "小", parity = predVal % 2 === 1 ? "单" : "双";
            return { form: size + parity, predVal, details: `X=${X}, Y=${Y}, Z=${Z}, 中间值=${mid}, 预测值=${predVal}` };
        }

        function algoWMA(records, window) {
            if (!window) window = getWMAParams();
            if (records.length < window) return null;
            let nums = records.slice(0, window).map(r => r.num);
            let weights = Array.from({ length: window }, (_, i) => i + 1);
            let wma = nums.reduce((s, n, i) => s + n * weights[i], 0) / weights.reduce((a, b) => a + b, 0);
            let size = wma >= 14 ? "大" : "小", parity = Math.round(wma) % 2 === 1 ? "单" : "双";
            return { form: size + parity, predVal: wma, details: `加权移动平均=${wma.toFixed(2)}` };
        }

        function algoMarkov(records, order) {
            if (!order) order = getMarkovOrder();
            if (records.length < 10) return null;
            let forms = records.map(r => r.form), states = ["大单","大双","小单","小双"], trans = {};
            states.forEach(s => trans[s] = {});
            for (let i = 0; i < forms.length - order; i++) {
                let cur = forms[i], nxt = forms[i + order];
                if (states.includes(cur) && states.includes(nxt)) trans[cur][nxt] = (trans[cur][nxt] || 0) + 1;
            }
            let lastForm = forms[0];
            if (!trans[lastForm] || Object.keys(trans[lastForm]).length === 0) return null;
            let total = Object.values(trans[lastForm]).reduce((a,b) => a + b, 0);
            let maxCount = 0, maxForm = null;
            for (let f in trans[lastForm]) { if (trans[lastForm][f] > maxCount) { maxCount = trans[lastForm][f]; maxForm = f; } }
            if (!maxForm) return null;
            return { form: maxForm, predVal: null, details: `从 ${lastForm} → ${maxForm} (概率 ${(maxCount/total*100).toFixed(1)}%)` };
        }

        function algoEnsemble(records) {
            let results = [];
            let r1 = algoThreeStep(records), r2 = algoWMA(records), r3 = algoMarkov(records);
            if (r1) results.push(r1.form);
            if (r2) results.push(r2.form);
            if (r3) results.push(r3.form);
            if (results.length === 0) return null;
            let count = {};
            results.forEach(f => count[f] = (count[f] || 0) + 1);
            let maxCount = 0, maxForm = null;
            for (let f in count) { if (count[f] > maxCount) { maxCount = count[f]; maxForm = f; } }
            return { form: maxForm, predVal: null, details: `综合 ${results.length} 种算法，最多票 ${maxForm}` };
        }

        function getStatRecommendations(records) {
            if (records.length < 10) return ["大单","大双","小单"];
            let recent = records.slice(0, 30), forms = recent.map(r => r.form), cnt = {};
            forms.forEach(f => cnt[f] = (cnt[f] || 0) + 1);
            let sorted = Object.entries(cnt).sort((a,b) => b[1] - a[1]);
            let main = sorted[0][0];
            let rec2 = sorted[1] ? sorted[1][0] : (main === "大单" ? "大双" : "大单");
            let rec3 = sorted[2] ? sorted[2][0] : (main === "大单" ? "小单" : "小双");
            return [main, rec2, rec3];
        }

        function getKillRecommendation(formCnt, total) {
            if (Object.keys(formCnt).length === 0) return ["大单", 0];
            let minForm = null, minCnt = Infinity;
            for (let f in formCnt) { if (formCnt[f] < minCnt) { minCnt = formCnt[f]; minForm = f; } }
            return [minForm, minCnt / total * 100];
        }

        function getHotColdNumbers(records) {
            let freq = Array(28).fill(0);
            records.forEach(r => { if (r.num >= 0 && r.num <= 27) freq[r.num]++; });
            let sorted = freq.map((v, i) => ({ num: i, count: v })).filter(f => f.count > 0).sort((a,b) => b.count - a.count);
            return { hot: sorted.slice(0,5).map(f => f.num), cold: sorted.slice(-5).map(f => f.num) };
        }

        function getConsecutiveStats(records) {
            if (records.length < 2) return { size:0, parity:0, form:0, sizeChar:'', parityChar:'', formChar:'' };
            let sizes = records.map(r => r.size), parities = records.map(r => r.parity), forms = records.map(r => r.form);
            let sizeRun = 1, parityRun = 1, formRun = 1;
            for (let i = 1; i < sizes.length; i++) { if (sizes[i] === sizes[0]) sizeRun++; else break; }
            for (let i = 1; i < parities.length; i++) { if (parities[i] === parities[0]) parityRun++; else break; }
            for (let i = 1; i < forms.length; i++) { if (forms[i] === forms[0]) formRun++; else break; }
            return { size: sizeRun, parity: parityRun, form: formRun, sizeChar: sizes[0], parityChar: parities[0], formChar: forms[0] };
        }

        function playSound() {
            try { const ctx = new (window.AudioContext || window.webkitAudioContext)(); const o = ctx.createOscillator(), g = ctx.createGain(); o.connect(g); g.connect(ctx.destination); o.frequency.value = 880; o.type = 'sine'; g.gain.setValueAtTime(0.1, ctx.currentTime); g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3); o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.3); } catch(e) {}
        }

        function recordPrediction(predicted, actual) {
            const now = new Date().toLocaleString('zh-CN');
