                html += `<tr><td>${item.time}</td><td>${item.predicted}</td><td>${item.actual || '--'}</td><td class="${cls}">${status}</td><td><button class="btn btn-small" onclick="markHistory(${index},'win')">✓</button><button class="btn btn-small" onclick="markHistory(${index},'lose')">✗</button> ${userMark}</td></tr>`;
            });
            tbody.innerHTML = html;
