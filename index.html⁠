            let html = '';
            records.slice(0,10).forEach(r => {
                const d = r.digits ? `${r.digits[0]},${r.digits[1]},${r.digits[2]}` : '--';
                html += `<tr><td>${r.expect}</td><td>${r.num}</td><td>${r.size || '--'}</td><td>${r.parity || '--'}</td><td>${d}</td></tr>`;
            });
            tbody.innerHTML = html;
        }

        function updateTransitionTip(records) {
            if (records.length < 2) { document.getElementById('transitionTip').textContent = '数据不足'; return; }
            const forms = records.map(r => r.form), trans = {};
            for (let i = 0; i < forms.length - 1; i++) { const cur = forms[i], nxt = forms[i+1]; if (!trans[cur]) trans[cur] = {}; trans[cur][nxt] = (trans[cur][nxt] || 0) + 1; }
            const lastForm = forms[0];
            if (!trans[lastForm] || Object.keys(trans[lastForm]).length === 0) { document.getElementById('transitionTip').textContent = '暂无转换数据'; return; }
            let maxCount = 0, maxForm = null;
            for (let f in trans[lastForm]) { if (trans[lastForm][f] > maxCount) { maxCount = trans[lastForm][f]; maxForm = f; } }
            const total = Object.values(trans[lastForm]).reduce((a,b) => a+b, 0);
            document.getElementById('transitionTip').textContent = `当前形态 ${lastForm} → 最可能 ${maxForm} (概率 ${(maxCount/total*100).toFixed(1)}%)`;
        }

        function updateBetSuggestion(records) {
            if (records.length < 10) { document.getElementById('betSuggestion').innerHTML = '数据不足'; return; }
            const stats = analyzeRecords(records);
            if (!stats) { document.getElementById('betSuggestion').innerHTML = '统计失败'; return; }
            const [rec1, rec2, rec3] = getStatRecommendations(stats);
            const kill = getKillRecommendation(stats.formCnt, stats.total)[0];
            document.getElementById('betSuggestion').innerHTML =
                `<span>⭐ 主推：<strong style="color:var(--theme-color);">${rec1}</strong></span>
                 <span>🔹 次推：<strong style="color:var(--theme-color);">${rec2}</strong></span>
                 <span>🛡 补防：<strong style="color:var(--theme-color);">${rec3}</strong></span>
                 <span>❌ 杀号：<strong style="color:#ff4757;">${kill}</strong></span>`;
        }

        function analyzeRecords(records, limit = 30) {
            if (records.length < 10) return null;
            let recent = records.slice(0, limit);
            let sizes = recent.map(r => r.size), parities = recent.map(r => r.parity), forms = recent.map(r => r.form);
            let sizeCnt = {}, parityCnt = {}, formCnt = {};
            sizes.forEach(s => sizeCnt[s] = (sizeCnt[s] || 0) + 1);
            parities.forEach(p => parityCnt[p] = (parityCnt[p] || 0) + 1);
            forms.forEach(f => formCnt[f] = (formCnt[f] || 0) + 1);
            return { sizeCnt, parityCnt, formCnt, total: recent.length };
        }

        function updateHotColdConsecutive(records) {
            if (!records || records.length === 0) return;
            const { hot, cold } = getHotColdNumbers(records);
            document.getElementById('hotNumbers').innerHTML = hot.map(n => `<span class="hot">${n}</span>`).join('');
            document.getElementById('coldNumbers').innerHTML = cold.map(n => `<span class="cold">${n}</span>`).join('');
            const cs = getConsecutiveStats(records);
            if (cs.size > 0) document.getElementById('consecutiveStats').innerHTML = `大小连出 ${cs.size} 期 (${cs.sizeChar}) &nbsp;|&nbsp; 单双连出 ${cs.parity} 期 (${cs.parityChar}) &nbsp;|&nbsp; 形态连出 ${cs.form} 期 (${cs.formChar})`;
            else document.getElementById('consecutiveStats').textContent = '--';
        }

        function renderPC28() {
            const resultDiv = document.getElementById('pc28Result');
            if (pc28Records.length < 3) { resultDiv.innerHTML = '数据不足 3 期'; return; }
            let records = pc28Records.map(r => classifyRecord(r));
            let algoType = document.getElementById('algorithmSelect').value;
            let algoResult = null;
            switch (algoType) {
                case 'three_step': algoResult = algoThreeStep(records); break;
                case 'wma': algoResult = algoWMA(records); break;
                case 'markov': algoResult = algoMarkov(records); break;
                case 'ensemble': algoResult = algoEnsemble(records); break;
                default: algoResult = algoThreeStep(records);
            }
            let latest = records.slice(0, 3);
            let [rec1, rec2, rec3] = getStatRecommendations(records);
            let html = '';
            html += '<div style="font-weight:600;margin-bottom:8px;">📈 最近3期数据</div>';
            latest.forEach(r => { html += `<div class="row"><span class="label">${r.expect}</span><span class="value">${r.num}（${r.size}${r.parity}）</span><span style="color:var(--text-muted);">${r.digits[0]}, ${r.digits[1]}, ${r.digits[2]}</span></div>`; });
            const algoName = document.getElementById('algorithmSelect').options[document.getElementById('algorithmSelect').selectedIndex].text;
            html += `<div style="font-weight:600;margin:12px 0 8px;">🧮 当前算法：${algoName}</div>`;
            if (algoResult) {
                html += `<div class="row"><span class="label">预测值</span><span style="font-weight:700;">${algoResult.predVal !== null ? algoResult.predVal : '--'}</span></div>`;
                html += `<div class="row"><span class="label">预测形态</span><span style="font-weight:700;color:#f5576c;">${algoResult.form}</span></div>`;
                html += `<div class="row"><span class="label">详情</span><span style="font-size:13px;color:var(--text-muted);">${algoResult.details}</span></div>`;
            } else {
                html += `<div style="color:var(--text-muted);">算法所需数据不足</div>`;
            }
            html += `<div style="font-weight:600;margin:12px 0 8px;">🎯 统计推荐</div>`;
            html += `<div class="rec-card rec-main">⭐ 主推：${rec1}</div>`;
            html += `<div class="rec-card">🔹 次推：${rec2}</div>`;
            html += `<div class="rec-card">🛡 补防：${rec3}</div>`;
            resultDiv.innerHTML = html;
            // 记录历史（只记录三步算法或综合的预测结果）
            if (algoResult && algoResult.form && latest.length > 0 && latest[0].form) {
                recordPrediction(algoResult.form, latest[0].form);
            }
        }

        async function fetchPC28Data() {
            const resultDiv = document.getElementById('pc28Result');
            resultDiv.innerHTML = '<div class="spinner"></div> 加载数据中...';
            try {
                const resp = await fetch('https://pc28.help/api/kj.json?nbr=20');
                const json = await resp.json();
                if (json && json.data && json.data.length > 0) {
                    pc28Records = json.data.map(item => ({ expect: item.nbr, num: parseInt(item.num) }));
                    pc28Records.sort((a,b) => parseInt(b.expect) - parseInt(a.expect));
                } else {
                    pc28Records = [
                        { expect: "3444534", num: 19 }, { expect: "3444533", num: 9 },
                        { expect: "3444532", num: 14 }, { expect: "3444531", num: 12 },
                        { expect: "3444530", num: 16 }, { expect: "3444529", num: 8 },
                        { expect: "3444528", num: 11 }, { expect: "3444527", num: 6 },
                        { expect: "3444526", num: 18 }, { expect: "3444525", num: 15 }
                    ];
                }
                document.getElementById('dataCount').textContent = `数据期数：${pc28Records.length}`;
                renderPC28();
                updateCharts(pc28Records);
                updateHotColdConsecutive(pc28Records);
                updateMissTrend(pc28Records);
                updateSumDist(pc28Records);
                updateRatio(pc28Records);
                updateDetailTable(pc28Records);
                updateTransitionTip(pc28Records);
                updateBetSuggestion(pc28Records);
                playSound();
            } catch (e) {
                console.warn('获取数据失败，使用演示数据', e);
                pc28Records = [
                    { expect: "3444534", num: 19 }, { expect: "3444533", num: 9 },
                    { expect: "3444532", num: 14 }, { expect: "3444531", num: 12 },
                    { expect: "3444530", num: 16 }, { expect: "3444529", num: 8 },
                    { expect: "3444528", num: 11 }, { expect: "3444527", num: 6 },
                    { expect: "3444526", num: 18 }, { expect: "3444525", num: 15 }
                ];
                document.getElementById('dataCount').textContent = `数据期数：${pc28Records.length}`;
                renderPC28();
                updateCharts(pc28Records);
                updateHotColdConsecutive(pc28Records);
                updateMissTrend(pc28Records);
                updateSumDist(pc28Records);
                updateRatio(pc28Records);
                updateDetailTable(pc28Records);
                updateTransitionTip(pc28Records);
                updateBetSuggestion(pc28Records);
            }
        }

        function manualRefreshPC28() {
            if (pc28Records.length > 0) { renderPC28(); updateCharts(pc28Records); updateHotColdConsecutive(pc28Records); updateMissTrend(pc28Records); updateSumDist(pc28Records); updateRatio(pc28Records); updateDetailTable(pc28Records); updateTransitionTip(pc28Records); updateBetSuggestion(pc28Records); countdownSeconds = 60; document.getElementById('countdownDisplay').textContent = '60秒'; } else fetchPC28Data();
        }

        document.getElementById('algorithmSelect').addEventListener('change', function() { if (pc28Records.length > 0) renderPC28(); });
        document.getElementById('wmaWindowSlider').addEventListener('input', function() { document.getElementById('wmaWindowDisplay').textContent = this.value; if (pc28Records.length > 0) { renderPC28(); updateBetSuggestion(pc28Records); } });
        document.getElementById('markovOrderSlider').addEventListener('input', function() { document.getElementById('markovOrderDisplay').textContent = this.value; if (pc28Records.length > 0) { renderPC28(); updateBetSuggestion(pc28Records); } });

        // ============================================================
        // 5. 网速测试
        // ============================================================
        async function testSpeed() {
            const status = document.getElementById('speedStatus');
            status.textContent = '测速中...';
            if ('connection' in navigator) {
                const conn = navigator.connection;
                const down = (conn.downlink || 0).toFixed(1);
                document.getElementById('downloadSpeed').textContent = down;
                document.getElementById('uploadSpeed').textContent = (down * 0.8).toFixed(1);
                status.textContent = '✅ 测速完成 (估算值)';
                return;
            }
            try {
                const start = Date.now();
                await fetch('https://www.google.com/images/phd/px.gif?t=' + Date.now(), { mode: 'no-cors' });
                const duration = (Date.now() - start) / 1000;
                const speed = (10 * 8) / (duration * 1024);
                const d = Math.max(0.1, speed).toFixed(1);
                document.getElementById('downloadSpeed').textContent = d;
                document.getElementById('uploadSpeed').textContent = (d * 0.8).toFixed(1);
                status.textContent = '✅ 测速完成 (估算)';
            } catch(e) {
                document.getElementById('downloadSpeed').textContent = '--';
                document.getElementById('uploadSpeed').textContent = '--';
                status.textContent = '❌ 测速失败';
            }
        }

        // ============================================================
        // 6. 汇率换算
        // ============================================================
        async function convertCurrency() {
            const from = document.getElementById('currencyFrom').value;
            const amount = parseFloat(document.getElementById('currencyAmount').value) || 1;
            const resultDiv = document.getElementById('currencyResult');
            resultDiv.textContent = '换算中...';
            try {
                const resp = await fetch(`https://api.exchangerate.host/latest?base=USD&symbols=CNY`);
                const data = await resp.json();
                let rateCNY = 7.23;
                if (data && data.rates && data.rates.CNY) rateCNY = data.rates.CNY;
                const rates = { USDT: 1 * rateCNY, TON: 5.67 * rateCNY, BTC: 65000 * rateCNY, ETH: 3500 * rateCNY, USD: 1 * rateCNY, EUR: 0.93 * rateCNY };
                const result = amount * rates[from];
                resultDiv.textContent = result.toFixed(2) + ' 人民币';
            } catch(e) {
                const rates = { USDT: 7.23, TON: 5.67, BTC: 65000, ETH: 3500, USD: 1, EUR: 0.93 };
                const result = amount * rates[from] * 7.23;
                resultDiv.textContent = result.toFixed(2) + ' 人民币 (估算)';
            }
        }

        // ============================================================
        // 7. USDT & TON 查询
        // ============================================================
        async function queryUSDT() {
            const address = document.getElementById('usdtAddress').value.trim();
            const resultDiv = document.getElementById('usdtResult');
            if (!address) { resultDiv.textContent = '⚠️ 请输入地址'; return; }
            resultDiv.innerHTML = '<div class="spinner"></div> 查询中...';
            try {
                const resp = await fetch(`https://api.trongrid.io/v1/accounts/${address}/trc20/balance?contract_address=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t`);
                const data = await resp.json();
                let balance = '0';
                if (data.data && data.data.length > 0) balance = (parseInt(data.data[0].balance) / 1e6).toFixed(2);
                resultDiv.textContent = `💰 余额：${balance} USDT`;
            } catch(e) {
                resultDiv.textContent = '❌ 查询失败，请稍后重试';
            }
        }

        async function queryTON() {
            const address = document.getElementById('tonAddress').value.trim();
            const resultDiv = document.getElementById('tonResult');
            if (!address) { resultDiv.textContent = '⚠️ 请输入地址'; return; }
            resultDiv.innerHTML = '<div class="spinner"></div> 查询中...';
            try {
                const resp = await fetch(`https://tonapi.io/v2/accounts/${address}`);
                const data = await resp.json();
                const balance = data.balance ? (parseInt(data.balance) / 1e9).toFixed(2) : '0';
                resultDiv.textContent = `💎 余额：${balance} TON`;
            } catch(e) {
                resultDiv.textContent = '❌ 查询失败，请稍后重试';
            }
        }

        // ============================================================
        // 8. 分享截图
        // ============================================================
        function sharePrediction() {
            html2canvas(document.querySelector('.container')).then(canvas => {
                canvas.toBlob(function(blob) {
                    if (navigator.share) {
                        navigator.share({ title: 'PC28预测结果', files: [new File([blob], 'prediction.png', { type: 'image/png' })] }).catch(() => {});
                    } else {
                        const link = document.createElement('a');
                        link.download = 'prediction.png';
                        link.href = canvas.toDataURL();
                        link.click();
                    }
                });
            });
        }

        // ============================================================
        // 9. 初始化
        // ============================================================
        fetchPC28Data();
        setTimeout(testSpeed, 1500);
        updateHistoryUI();
        updateWinRates();
    </script>
