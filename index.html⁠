            if (confirm('确定清除所有预测历史吗？')) { predictionHistory = []; localStorage.removeItem('predictionHistory'); updateHistoryUI(); updateWinRates(); }
        }

        function updateCharts(records) {
            const nums = records.slice(0,20).map(r => r.num).reverse();
            const labels = records.slice(0,20).map(r => r.expect).reverse();
            const ctxTrend = document.getElementById('trendChart').getContext('2d');
