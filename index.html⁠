            document.getElementById('countdownDisplay').textContent = '60秒';
        }
        function requestNotificationPermission() {
            if ('Notification' in window) {
                if (Notification.permission === 'default') Notification.requestPermission().then(p => notificationPermission = (p === 'granted'));
                else if (Notification.permission === 'granted') notificationPermission = true;
