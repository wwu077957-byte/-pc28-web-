<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>PC28 智能预测</title>
    <style>
        /* ===== 全局重置 & 字体 ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: #0d0f14;
            color: #e8edf5;
            min-height: 100vh;
            padding: 16px 12px 40px;
            display: flex;
            justify-content: center;
        }

        .app-container {
            max-width: 800px;
            width: 100%;
            margin: 0 auto;
        }

        /* ===== 顶部栏 ===== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0 16px;
            border-bottom: 1px solid #2a2f3a;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, #f7971e, #ffd200);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 0.5px;
        }

        .logo-sub {
            font-size: 13px;
            color: #8892a8;
            font-weight: 400;
            -webkit-text-fill-color: #8892a8;
            background: none;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 14px;
        }

        .header-right .time {
            color: #8892a8;
            font-size: 13px;
        }

        .header-right .tg-link {
            color: #58a9ff;
            text-decoration: none;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 4px;
            background: #1a2332;
            padding: 4px 12px;
            border-radius: 20px;
            border: 1px solid #2a3a55;
            transition: all 0.2s;
        }

        .header-right .tg-link:hover {
            background: #24324a;
            border-color: #4a7ab5;
        }

        .header-right .tg-link svg {
            width: 16px;
            height: 16px;
            fill: #58a9ff;
        }

        /* ===== 最新一期卡片 ===== */
        .latest-card {
            background: #161b24;
            border-radius: 16px;
            padding: 18px 20px;
            margin-bottom: 20px;
            border: 1px solid #262d3a;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
        }

        .latest-left {
            display: flex;
            align-items: center;
            gap: 18px;
            flex-wrap: wrap;
        }

        .latest-issue {
            font-size: 15px;
            color: #8892a8;
        }

        .latest-issue strong {
            color: #e8edf5;
            font-weight: 600;
            font-size: 17px;
        }

        .latest-numbers {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .latest-numbers .ball {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            background: #1e2a3a;
            color: #e8edf5;
            border: 1px solid #334155;
        }

        .latest-numbers .ball.ball-a {
            background: #2d3748;
            border-color: #4a5568;
        }
        .latest-numbers .ball.ball-b {
            background: #2d3748;
            border-color: #4a5568;
        }
        .latest-numbers .ball.ball-c {
            background: #2d3748;
            border-color: #4a5568;
        }

        .latest-sum {
            font-size: 15px;
            color: #8892a8;
            margin-left: 4px;
        }

        .latest-sum strong {
            color: #f7d44a;
            font-weight: 600;
        }

        .latest-tags {
            display: flex;
            gap: 8px;
            margin-left: 6px;
        }

        .tag {
            padding: 2px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .tag-small {
            background: #1a3a3a;
            color: #5fc9c9;
            border: 1px solid #2a5a5a;
        }

        .tag-big {
            background: #3a2a1a;
            color: #f7b84a;
            border: 1px solid #5a4a2a;
        }

        .tag-odd {
            background: #2a1a3a;
            color: #c97ad4;
            border: 1px solid #4a2a5a;
        }

        .tag-even {
            background: #1a2a3a;
            color: #5a9fd4;
            border: 1px solid #2a4a5a;
        }

        .latest-right {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-refresh {
            background: #1e2a3a;
            border: 1px solid #334155;
            color: #e8edf5;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-refresh:hover {
            background: #2a3a4a;
            border-color: #4a6a8a;
        }

        .btn-refresh:active {
            transform: scale(0.96);
        }

        .btn-refresh svg {
            width: 14px;
            height: 14px;
            fill: #8892a8;
        }

        /* ===== 推荐区域 ===== */
        .recommend-section {
            background: #161b24;
            border-radius: 16px;
            padding: 18px 20px 20px;
            margin-bottom: 20px;
            border: 1px solid #262d3a;
        }

        .recommend-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .recommend-title {
            font-size: 17px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .recommend-title .icon {
            font-size: 20px;
        }

        .recommend-badge {
            font-size: 12px;
            background: #1a2a3a;
            color: #5a9fd4;
            padding: 2px 12px;
            border-radius: 20px;
            border: 1px solid #2a4a5a;
        }

        .recommend-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .recommend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #0d1118;
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid #1f2835;
            transition: all 0.2s;
        }

        .recommend-item:hover {
            border-color: #334155;
            background: #11171f;
        }

        .recommend-item .label {
            font-size: 13px;
            color: #8892a8;
            font-weight: 500;
            min-width: 60px;
        }

        .recommend-item .result {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .recommend-item .result .result-tag {
            padding: 2px 16px;
            border-radius: 20px;
            font-size: 16px;
        }

        .result-tag.tag-big {
            background: #3a2a1a;
            color: #f7b84a;
            border: 1px solid #5a4a2a;
        }

        .result-tag.tag-small {
            background: #1a3a3a;
            color: #5fc9c9;
            border: 1px solid #2a5a5a;
        }

        .result-tag.tag-odd {
            background: #2a1a3a;
            color: #c97ad4;
            border: 1px solid #4a2a5a;
        }

        .result-tag.tag-even {
            background: #1a2a3a;
            color: #5a9fd4;
            border: 1px solid #2a4a5a;
        }

        .result-tag.tag-big-odd {
            background: #3a2a1a;
            color: #f7b84a;
            border: 1px solid #5a4a2a;
        }
        .result-tag.tag-big-even {
            background: #3a2a1a;
            color: #f7b84a;
            border: 1px solid #5a4a2a;
        }
        .result-tag.tag-small-odd {
            background: #1a3a3a;
            color: #5fc9c9;
            border: 1px solid #2a5a5a;
        }
        .result-tag.tag-small-even {
            background: #1a3a3a;
            color: #5fc9c9;
            border: 1px solid #2a5a5a;
        }

        .recommend-item .actions {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .btn-copy {
            background: transparent;
            border: 1px solid #2a3a4a;
            color: #8892a8;
            padding: 4px 14px;
            border-radius: 16px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .btn-copy:hover {
            background: #1a2a3a;
            border-color: #4a7a9a;
            color: #e8edf5;
        }

        .btn-copy:active {
            transform: scale(0.94);
        }

        .btn-copy.copied {
            border-color: #4ac97a;
            color: #4ac97a;
            background: #1a3a2a;
        }

        .btn-copy svg {
            width: 14px;
            height: 14px;
            fill: currentColor;
        }

        .recommend-empty {
            color: #5a6a7a;
            text-align: center;
            padding: 20px 0;
            font-size: 14px;
        }

        /* ===== 历史表格 ===== */
        .history-section {
            background: #161b24;
            border-radius: 16px;
            padding: 16px 16px 12px;
            border: 1px solid #262d3a;
            overflow: hidden;
        }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .history-title {
            font-size: 15px;
            font-weight: 600;
            color: #e8edf5;
        }

        .history-count {
            font-size: 12px;
            color: #5a6a7a;
        }

        .table-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .history-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            min-width: 480px;
        }

        .history-table th {
            text-align: center;
            padding: 8px 4px;
            color: #6a7a8a;
            font-weight: 500;
            font-size: 12px;
            border-bottom: 1px solid #1f2835;
            letter-spacing: 0.5px;
        }

        .history-table td {
            text-align: center;
            padding: 8px 4px;
            border-bottom: 1px solid #141a22;
            font-weight: 400;
        }

        .history-table tr:last-child td {
            border-bottom: none;
        }

        .history-table .issue-cell {
            color: #8892a8;
            font-size: 13px;
            font-weight: 500;
        }

        .history-table .num-cell {
            font-weight: 600;
            font-size: 15px;
            color: #e8edf5;
        }

        .history-table .sum-cell {
            font-weight: 600;
            color: #f7d44a;
        }

        .history-table .size-cell {
            font-weight: 500;
        }

        .history-table .size-cell.small {
            color: #5fc9c9;
        }
        .history-table .size-cell.big {
            color: #f7b84a;
        }

        .history-table .parity-cell {
            font-weight: 500;
        }
        .history-table .parity-cell.odd {
            color: #c97ad4;
        }
        .history-table .parity-cell.even {
            color: #5a9fd4;
        }

        .history-table .history-ball {
            display: inline-block;
            width: 28px;
            height: 28px;
            line-height: 28px;
            border-radius: 50%;
            text-align: center;
            font-size: 13px;
            font-weight: 600;
            background: #1a2332;
            color: #e8edf5;
            border: 1px solid #2a3a4a;
            margin: 0 1px;
        }

        .loading-text {
            color: #5a6a7a;
            text-align: center;
            padding: 30px 0;
            font-size: 14px;
        }

        .error-text {
            color: #d45a5a;
            text-align: center;
            padding: 30px 0;
            font-size: 14px;
        }

        .status-bar {
            display: flex;
            justify-content: flex-end;
            padding-top: 10px;
            font-size: 12px;
            color: #4a5a6a;
            gap: 16px;
            flex-wrap: wrap;
        }

        /* ===== Toast ===== */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(80px);
            background: #1a2a3a;
            color: #e8edf5;
            padding: 10px 24px;
            border-radius: 30px;
            font-size: 14px;
            border: 1px solid #2a4a5a;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.6);
            opacity: 0;
            transition: all 0.4s ease;
            pointer-events: none;
            z-index: 999;
            white-space: nowrap;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ===== 响应式 ===== */
        @media (max-width: 640px) {
            .header {
                flex-direction: column;
                align-items: stretch;
                gap: 6px;
            }
            .header-left {
                justify-content: center;
            }
            .header-right {
                justify-content: center;
                flex-wrap: wrap;
            }
            .latest-card {
                flex-direction: column;
                align-items: stretch;
                gap: 12px;
                padding: 14px 16px;
            }
            .latest-left {
                justify-content: center;
                gap: 10px;
            }
            .latest-right {
                justify-content: center;
            }
            .latest-numbers .ball {
                width: 32px;
                height: 32px;
                font-size: 15px;
            }
            .recommend-item {
                flex-wrap: wrap;
                gap: 8px;
            }
            .recommend-item .result {
                font-size: 17px;
                flex-wrap: wrap;
            }
            .recommend-item .actions {
                margin-left: auto;
            }
            .history-table {
                font-size: 12px;
                min-width: 400px;
            }
            .history-table .history-ball {
                width: 24px;
                height: 24px;
                line-height: 24px;
                font-size: 11px;
            }
            .toast {
                font-size: 12px;
                padding: 8px 18px;
                bottom: 20px;
            }
            .logo {
                font-size: 18px;
            }
            .header-right .time {
                font-size: 12px;
            }
        }

        @media (max-width: 420px) {
            .latest-left {
                flex-direction: column;
                gap: 6px;
            }
            .latest-numbers {
                gap: 6px;
            }
            .latest-numbers .ball {
                width: 28px;
                height: 28px;
                font-size: 13px;
            }
            .recommend-item {
                padding: 10px 12px;
            }
            .recommend-item .result {
                font-size: 15px;
            }
            .btn-copy {
                padding: 2px 10px;
                font-size: 11px;
            }
        }
    </style>
</head>
<body>

    <div class="app-container">
        <!-- ===== Toast ===== -->
        <div id="toast" class="toast">已复制</div>

        <!-- ===== 顶部 ===== -->
        <header class="header">
            <div class="header-left">
                <span class="logo">PC28 <span class="logo-sub">智能预测</span></span>
            </div>
            <div class="header-right">
                <span class="time" id="headerTime">--:--</span>
                <a href="https://t.me/ero6v" target="_blank" class="tg-link" rel="noopener">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.1-.2-.11-.06-.27-.04-.39-.02-.17.03-2.86 1.82-3.19 2.02-.3.18-.57.27-.82.27-.27 0-.78-.15-1.16-.27-.48-.15-.86-.23-.83-.48.02-.13.2-.27.55-.41 2.1-.91 3.5-1.51 4.2-1.8 2-.86 2.42-.94 2.69-.94.06 0 .17.01.25.08.06.05.1.13.09.23-.04.15-.06.18-.16.18z"/></svg>
                    @ero6v
                </a>
            </div>
        </header>

        <!-- ===== 最新一期 ===== -->
        <div class="latest-card" id="latestCard">
            <div class="latest-left">
                <div class="latest-issue">
                    期号 <strong id="latestIssue">------</strong>
                </div>
                <div class="latest-numbers" id="latestNumbers">
                    <span class="ball ball-a">-</span>
                    <span class="ball ball-b">-</span>
                    <span class="ball ball-c">-</span>
                </div>
                <div class="latest-sum">
                    和值 <strong id="latestSum">--</strong>
                </div>
                <div class="latest-tags" id="latestTags">
                    <span class="tag tag-small">小</span>
                    <span class="tag tag-even">双</span>
                </div>
            </div>
            <div class="latest-right">
                <button class="btn-refresh" id="btnRefresh" title="手动刷新数据">
                    <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0 0 12 4C7.58 4 4.01 7.58 4.01 12S7.58 20 12 20c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                    刷新
                </button>
            </div>
        </div>

        <!-- ===== 推荐区域 ===== -->
        <div class="recommend-section" id="recommendSection">
            <div class="recommend-header">
                <div class="recommend-title">
                    <span class="icon">🧠</span> AI 推荐
                    <span class="recommend-badge" id="recommendBadge">2 个</span>
                </div>
                <div style="display:flex; gap:6px; align-items:center;">
                    <button class="btn-copy" id="btnCopyAll" style="border-color:#2a4a5a; color:#5a9fd4; padding:4px 16px;">
                        📋 全部复制
                    </button>
                </div>
            </div>
            <div class="recommend-list" id="recommendList">
                <div class="recommend-empty">加载数据中...</div>
            </div>
        </div>

        <!-- ===== 历史数据 ===== -->
        <div class="history-section">
            <div class="history-header">
                <span class="history-title">📊 历史走势</span>
                <span class="history-count" id="historyCount">共 0 期</span>
            </div>
            <div class="table-wrap">
                <table class="history-table" id="historyTable">
                    <thead>
                        <tr>
                            <th>期号</th>
                            <th>A</th>
                            <th>B</th>
                            <th>C</th>
                            <th>和值</th>
                            <th>大小</th>
                            <th>单双</th>
                        </tr>
                    </thead>
                    <tbody id="historyBody">
                        <tr><td colspan="7" class="loading-text">加载中...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="status-bar">
                <span id="statusData">数据来源：加载中...</span>
                <span id="statusTime">更新：--</span>
            </div>
        </div>
    </div>

    <script>
        // ============================================================
        //  配置
        // ============================================================
        const CONFIG = {
            HISTORY_URL: 'https://pc28.help/api/kj.json?nbr=20',
            // 备用接口（暂时不用，但保留）
            BACKUP_URL: 'https://pc28.help/api/yl.json',
            // 用于判断走势混乱的阈值（最近8期大小+单双变化次数 ≥ 此值则混乱）
            CHAOS_THRESHOLD: 6,
            // 最大推荐数
            MAX_RECOMMEND: 3,
            // 默认推荐数（不混乱时）
            DEFAULT_RECOMMEND_COUNT: 2,
        };

        // ============================================================
        //  状态
        // ============================================================
        let allData = []; // 完整历史数据（最新在前）
        let latestItem = null; // 最新一期
        let isRefreshing = false;

        // ============================================================
        //  DOM 引用
        // ============================================================
        const $ = id => document.getElementById(id);
        const latestIssue = $('latestIssue');
        const latestNumbers = $('latestNumbers');
        const latestSum = $('latestSum');
        const latestTags = $('latestTags');
        const historyBody = $('historyBody');
        const historyCount = $('historyCount');
        const recommendList = $('recommendList');
        const recommendBadge = $('recommendBadge');
        const statusData = $('statusData');
        const statusTime = $('statusTime');
        const headerTime = $('headerTime');
        const toastEl = $('toast');
        let toastTimer = null;

        // ============================================================
        //  工具函数
        // ============================================================
        function getNowStr() {
            const d = new Date();
            const pad = n => String(n).padStart(2, '0');
            return `${pad(d.getHours())}:${pad(d.getMinutes())}`;
        }

        function showToast(msg = '已复制', duration = 1800) {
            toastEl.textContent = msg;
            toastEl.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
                toastEl.classList.remove('show');
            }, duration);
        }

        // 从期号字符串提取数字部分（用于排序）
        function parseIssueNum(issueStr) {
            return parseInt(issueStr.replace(/[^0-9]/g, ''), 10) || 0;
        }

        // 判断大小 —— 修改为 0-13 小，14及以上 大（解决预测值超出27的问题）
        function getSize(sum) {
            const num = Number(sum);
            if (num >= 0 && num <= 13) return '小';
            if (num >= 14) return '大';
            return '--';
        }

        // 判断单双
        function getParity(sum) {
            const num = Number(sum);
            if (isNaN(num)) return '--';
            return num % 2 === 0 ? '双' : '单';
        }

        // 获取组合标签 (大/小 + 单/双)
        function getCombination(sum) {
            const s = getSize(sum);
            const p = getParity(sum);
            if (s === '--' || p === '--') return '--';
            return s + p;
        }

        // 获取CSS类名
        function getSizeClass(size) { return size === '大' ? 'tag-big' : 'tag-small'; }

        function getParityClass(parity) { return parity === '单' ? 'tag-odd' : 'tag-even'; }

        function getCombinationClass(comb) {
            const map = {
                '大单': 'tag-big-odd',
                '大双': 'tag-big-even',
                '小单': 'tag-small-odd',
                '小双': 'tag-small-even'
            };
            return map[comb] || '';
        }

        // ============================================================
        //  核心算法
        // ============================================================
        /**
         * 使用用户算法预测第 N 期
         * @param {Array} history 历史数据数组，按时间降序（最新在前）
         * @param {number} nIndex 预测第几期（0 = 最新一期之后的第一期）
         * @param {object} options 提取规则配置
         * @returns {object|null} { sum, size, parity, combination, detail }
         */
        function predictWithAlgorithm(history, nIndex = 0, options = null) {
            // 默认提取规则 (用户标准算法)
            const defaultRule = {
                xSource: 'tens', // N-1期: 'tens' 十位, 'units' 个位
                ySource: 'first', // N-2期: 'first' 第1位, 'second' 第2位, 'third' 第3位
                zSource: 'third', // N-3期: 'first' 第1位, 'second' 第2位, 'third' 第3位
            };
            const rule = { ...defaultRule, ...options };

            // 需要 N-1, N-2, N-3 期数据
            const idx1 = nIndex + 0; // N-1
            const idx2 = nIndex + 1; // N-2
            const idx3 = nIndex + 2; // N-3

            if (idx1 >= history.length || idx2 >= history.length || idx3 >= history.length) {
                return null; // 数据不足
            }

            const n1 = history[idx1];
            const n2 = history[idx2];
            const n3 = history[idx3];

            // 提取数字
            let X, Y, Z;

            // X: 从 N-1 期提取
            if (rule.xSource === 'tens') {
                // 十位数：三位数的中间一位（B）
                X = n1.b;
            } else { // 'units'
                // 个位数：三位数的最后一位（C）
                X = n1.c;
            }

            // Y: 从 N-2 期提取
            const digits2 = [n2.a, n2.b, n2.c];
            if (rule.ySource === 'first') Y = digits2[0];
            else if (rule.ySource === 'second') Y = digits2[1];
            else if (rule.ySource === 'third') Y = digits2[2];
            else Y = digits2[0];

            // Z: 从 N-3 期提取
            const digits3 = [n3.a, n3.b, n3.c];
            if (rule.zSource === 'first') Z = digits3[0];
            else if (rule.zSource === 'second') Z = digits3[1];
            else if (rule.zSource === 'third') Z = digits3[2];
            else Z = digits3[2];

            // 计算中间值
            const mid = X + Y + Z;

            // N-1 期最终结果（和值）
            const n1Sum = n1.sum;

            // 预测值
            const predSum = mid + n1Sum;

            // 判断形态
            const size = getSize(predSum);
            const parity = getParity(predSum);
            const combination = size + parity;

            return {
                sum: predSum,
                size: size,
                parity: parity,
                combination: combination,
                detail: {
                    X,
                    Y,
                    Z,
                    mid,
                    n1Sum,
                    n1Issue: n1.issue,
                    n2Issue: n2.issue,
                    n3Issue: n3.issue,
                }
            };
        }

        /**
         * 获取多个不同的推荐
         * @param {Array} history 历史数据
         * @param {number} count 需要几个推荐 (2 或 3)
         * @param {boolean} isChaos 是否混乱
         * @returns {Array} 推荐结果数组
         */
        function getRecommendations(history, count = 2, isChaos = false) {
            if (history.length < 4) return [];

            // 定义算法变体
            const variants = [
                // 变体0: 标准算法 (推荐一)
                { name: '推荐一', rule: { xSource: 'tens', ySource: 'first', zSource: 'third' } },
                // 变体1: 推荐二
                { name: '推荐二', rule: { xSource: 'units', ySource: 'second', zSource: 'first' } },
                // 变体2: 推荐三
                { name: '推荐三', rule: { xSource: 'tens', ySource: 'third', zSource: 'second' } },
                // 额外变体 (备用)
                { name: '推荐四', rule: { xSource: 'units', ySource: 'first', zSource: 'second' } },
                { name: '推荐五', rule: { xSource: 'tens', ySource: 'second', zSource: 'first' } },
                { name: '推荐六', rule: { xSource: 'units', ySource: 'third', zSource: 'third' } },
            ];

            const results = [];
            const usedCombinations = new Set();

            // 先计算所有变体的结果
            const allResults = variants.map(v => {
                const res = predictWithAlgorithm(history, 0, v.rule);
                return { ...res, variantName: v.name, rule: v.rule };
            }).filter(r => r !== null && r.combination !== '--');

            // 去重（保留第一个出现的）
            const uniqueResults = [];
            const seen = new Set();
            for (const r of allResults) {
                const key = r.combination;
                if (!seen.has(key)) {
                    seen.add(key);
                    uniqueResults.push(r);
                }
            }

            // 推荐一: 使用标准算法 (变体0)
            const stdResult = uniqueResults.find(r => r.variantName === '推荐一');
            if (!stdResult) return [];

            const finalResults = [];
            // 先加入推荐一
            finalResults.push({
                label: '推荐一',
                combination: stdResult.combination,
                sum: stdResult.sum,
                size: stdResult.size,
                parity: stdResult.parity,
                detail: stdResult.detail,
                rule: stdResult.rule,
                isPrimary: true,
            });
            usedCombinations.add(stdResult.combination);

            // 从剩余结果中挑选与已有不同的
            const candidates = uniqueResults.filter(r => r.variantName !== '推荐一' && !usedCombinations.has(r
            .combination));

            // 按顺序取需要的数量
            const need = count - 1;
            let taken = 0;
            for (const c of candidates) {
                if (taken >= need) break;
                if (!usedCombinations.has(c.combination)) {
                    finalResults.push({
                        label: c.variantName,
                        combination: c.combination,
                        sum: c.sum,
                        size: c.size,
                        parity: c.parity,
                        detail: c.detail,
                        rule: c.rule,
                        isPrimary: false,
                    });
                    usedCombinations.add(c.combination);
                    taken++;
                }
            }

            // 如果还是不够，从所有结果中补充（但必须不同）
            if (taken < need) {
                for (const r of uniqueResults) {
                    if (taken >= need) break;
                    if (!usedCombinations.has(r.combination) && r.variantName !== '推荐一') {
                        finalResults.push({
                            label: r.variantName,
                            combination: r.combination,
                            sum: r.sum,
                            size: r.size,
                            parity: r.parity,
                            detail: r.detail,
                            rule: r.rule,
                            isPrimary: false,
                        });
                        usedCombinations.add(r.combination);
                        taken++;
                    }
                }
            }

            // 如果还是不够，尝试用算法生成不同的组合（但必须基于算法）
            if (taken < need) {
                const offsets = [1, 2, 3, 4];
                for (const off of offsets) {
                    if (taken >= need) break;
                    const res = predictWithAlgorithm(history, off, { xSource: 'tens', ySource: 'first',
                        zSource: 'third' });
                    if (res && res.combination !== '--' && !usedCombinations.has(res.combination)) {
                        finalResults.push({
                            label: `推荐${finalResults.length + 1}`,
                            combination: res.combination,
                            sum: res.sum,
                            size: res.size,
                            parity: res.parity,
                            detail: res.detail,
                            rule: { offset: off, ...{ xSource: 'tens', ySource: 'first', zSource: 'third' } },
                            isPrimary: false,
                        });
                        usedCombinations.add(res.combination);
                        taken++;
                    }
                }
            }

            return finalResults;
        }

        // ============================================================
        //  判断走势是否混乱
        // ============================================================
        function isTrendChaotic(history, lookback = 8) {
            if (history.length < lookback + 1) return false;

            const recent = history.slice(0, lookback);
            let sizeChanges = 0;
            let parityChanges = 0;

            for (let i = 1; i < recent.length; i++) {
                if (recent[i].size !== recent[i - 1].size) sizeChanges++;
                if (recent[i].parity !== recent[i - 1].parity) parityChanges++;
            }

            const totalChanges = sizeChanges + parityChanges;
            return totalChanges >= CONFIG.CHAOS_THRESHOLD;
        }

        // ============================================================
        //  数据获取
        // ============================================================
        async function fetchData() {
            // 使用主接口 kj.json
            const url = CONFIG.HISTORY_URL;
            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-cache',
                });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const data = await response.json();
                return data;
            } catch (err) {
                console.warn('主接口失败，尝试备用接口...', err);
                // 备用接口 yl.json 数据结构不同，暂时只作为兜底，但可能无法解析
                // 这里简单抛出错误，让上层处理
                throw new Error('数据获取失败，请检查网络或稍后重试');
            }
        }

        /**
         * 解析接口返回的数据 —— 适配 kj.json 的实际字段
         */
        function parseApiData(raw) {
            let list = null;

            if (Array.isArray(raw)) {
                list = raw;
            } else if (raw && typeof raw === 'object') {
                // 优先取 data 字段（kj.json 的结构）
                if (Array.isArray(raw.data)) {
                    list = raw.data;
                } else if (Array.isArray(raw.list)) {
                    list = raw.list;
                } else if (Array.isArray(raw.result)) {
                    list = raw.result;
                } else {
                    // 兜底：取第一个数组属性
                    for (const key of Object.keys(raw)) {
                        if (Array.isArray(raw[key]) && raw[key].length > 0) {
                            list = raw[key];
                            break;
                        }
                    }
                }
            }

            if (!list || list.length === 0) {
                throw new Error('数据格式无法识别或为空');
            }

            // 标准化每条数据 —— 适配 kj.json 的字段
            return list.map(item => {
                // 期号: nbr
                let issue = item.nbr || item.issue || item.period || '';
                issue = String(issue).trim();

                // 三个数字: 从 "8+3+6" 解析
                let a = null, b = null, c = null;
                const numberStr = item.number || item.numStr || '';
                if (numberStr) {
                    const parts = String(numberStr).split('+').map(Number);
                    if (parts.length === 3) {
                        a = parts[0];
                        b = parts[1];
                        c = parts[2];
                    }
                }

                // 如果 number 字段解析失败，尝试单独字段
                if (a === null || b === null || c === null) {
                    a = item.a ?? item.num1 ?? null;
                    b = item.b ?? item.num2 ?? null;
                    c = item.c ?? item.num3 ?? null;
                }

                // 确保是数字
                a = Number(a);
                b = Number(b);
                c = Number(c);

                // 和值: num
                let sum = item.num || item.sum || item.total || null;
                if (sum === null || sum === undefined) {
                    if (!isNaN(a) && !isNaN(b) && !isNaN(c)) {
                        sum = a + b + c;
                    } else {
                        sum = 0;
                    }
                }
                sum = Number(sum);

                // 大小单双: 从 combination 获取，或自行计算
                let size = '';
                let parity = '';
                if (item.combination) {
                    const comb = String(item.combination);
                    if (comb.includes('大')) size = '大';
                    else if (comb.includes('小')) size = '小';
                    if (comb.includes('单')) parity = '单';
                    else if (comb.includes('双')) parity = '双';
                }
                if (!size) size = getSize(sum);
                if (!parity) parity = getParity(sum);

                return {
                    issue: String(issue),
                    a, b, c,
                    sum,
                    size: String(size),
                    parity: String(parity),
                    _raw: item,
                };
            }).filter(item => item.issue && !isNaN(item.a) && !isNaN(item.b) && !isNaN(item.c));
        }

        // ============================================================
        //  渲染
        // ============================================================

        // 渲染最新一期
        function renderLatest(item) {
            if (!item) {
                latestIssue.textContent = '------';
                latestNumbers.innerHTML = `
                    <span class="ball ball-a">-</span>
                    <span class="ball ball-b">-</span>
                    <span class="ball ball-c">-</span>
                `;
                latestSum.textContent = '--';
                latestTags.innerHTML = `<span class="tag tag-small">小</span><span class="tag tag-even">双</span>`;
                return;
            }

            latestIssue.textContent = item.issue;
            latestNumbers.innerHTML = `
                <span class="ball ball-a">${item.a}</span>
                <span class="ball ball-b">${item.b}</span>
                <span class="ball ball-c">${item.c}</span>
            `;
            latestSum.textContent = item.sum;

            const sizeCls = getSizeClass(item.size);
            const parityCls = getParityClass(item.parity);
            latestTags.innerHTML = `
                <span class="tag ${sizeCls}">${item.size}</span>
                <span class="tag ${parityCls}">${item.parity}</span>
            `;
        }

        // 渲染历史表格
        function renderHistory(data) {
            if (!data || data.length === 0) {
                historyBody.innerHTML = `<tr><td colspan="7" class="loading-text">暂无数据</td></tr>`;
                historyCount.textContent = '共 0 期';
                return;
            }

            let html = '';
            const showCount = Math.min(data.length, 30);
            for (let i = 0; i < showCount; i++) {
                const item = data[i];
                const sizeCls = item.size === '大' ? 'big' : 'small';
                const parityCls = item.parity === '单' ? 'odd' : 'even';
                html += `
                    <tr>
                        <td class="issue-cell">${item.issue}</td>
                        <td class="num-cell"><span class="history-ball">${item.a}</span></td>
                        <td class="num-cell"><span class="history-ball">${item.b}</span></td>
                        <td class="num-cell"><span class="history-ball">${item.c}</span></td>
                        <td class="sum-cell">${item.sum}</td>
                        <td class="size-cell ${sizeCls}">${item.size}</td>
                        <td class="parity-cell ${parityCls}">${item.parity}</td>
                    </tr>
                `;
            }
            historyBody.innerHTML = html;
            historyCount.textContent = `共 ${data.length} 期 (显示最近 ${showCount} 期)`;
        }

        // 渲染推荐
        function renderRecommendations(history) {
            if (!history || history.length < 4) {
                recommendList.innerHTML = `<div class="recommend-empty">数据不足，无法生成推荐 (需要至少4期数据)</div>`;
                recommendBadge.textContent = '0 个';
                return;
            }

            // 判断走势是否混乱
            const chaotic = isTrendChaotic(history);
            const recommendCount = chaotic ? 3 : CONFIG.DEFAULT_RECOMMEND_COUNT;

            // 获取推荐
            const recs = getRecommendations(history, recommendCount, chaotic);

            if (!recs || recs.length === 0) {
                recommendList.innerHTML = `<div class="recommend-empty">无法生成推荐，请稍后重试</div>`;
                recommendBadge.textContent = '0 个';
                return;
            }

            // 更新badge
            recommendBadge.textContent = `${recs.length} 个${chaotic ? ' 🔀 走势混乱' : ''}`;

            // 渲染每个推荐
            let html = '';
            for (let i = 0; i < recs.length; i++) {
                const r = recs[i];
                const comb = r.combination;
                const combCls = getCombinationClass(comb);
                const label = r.isPrimary ? '⭐ 推荐一' : r.label;
                const copyText = comb; // 单个复制只复制组合

                html += `
                    <div class="recommend-item" data-combination="${comb}">
                        <div class="label">${label}</div>
                        <div class="result">
                            <span class="result-tag ${combCls}">${comb}</span>
                            <span style="font-size:13px;color:#5a6a7a;font-weight:400;">${r.sum}</span>
                        </div>
                        <div class="actions">
                            <button class="btn-copy btn-copy-single" data-text="${copyText}" title="复制此推荐">
                                <svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                                复制
                            </button>
                        </div>
                    </div>
                `;
            }

            recommendList.innerHTML = html;

            // 绑定单个复制事件
            document.querySelectorAll('.btn-copy-single').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const text = this.dataset.text || '';
                    copyToClipboard(text, `已复制: ${text}`);
                    this.classList.add('copied');
                    setTimeout(() => this.classList.remove('copied'), 1500);
                });
            });

            // 绑定全部复制
            const allBtn = document.getElementById('btnCopyAll');
            if (allBtn) {
                allBtn.onclick = function() {
                    const items = document.querySelectorAll('.recommend-item');
                    const texts = [];
                    items.forEach(el => {
                        const comb = el.dataset.combination || '';
                        if (comb) texts.push(comb);
                    });
                    if (texts.length === 0) {
                        showToast('没有可复制的内容', 1200);
                        return;
                    }
                    const content = texts.join('\n');
                    copyToClipboard(content, `已复制 ${texts.length} 个推荐`);
                };
            }
        }

        // ============================================================
        //  复制功能
        // ============================================================
        function copyToClipboard(text, toastMsg) {
            if (!text) {
                showToast('内容为空', 1000);
                return;
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => {
                    showToast(toastMsg || '已复制');
                }).catch(() => {
                    fallbackCopy(text, toastMsg);
                });
            } else {
                fallbackCopy(text, toastMsg);
            }
        }

        function fallbackCopy(text, toastMsg) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            textarea.style.top = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                showToast(toastMsg || '已复制');
            } catch (err) {
                showToast('复制失败，请手动复制', 1500);
            }
            document.body.removeChild(textarea);
        }

        // ============================================================
        //  主流程
        // ============================================================
        async function loadData(showLoading = true) {
            if (isRefreshing) return;
            isRefreshing = true;

            if (showLoading) {
                historyBody.innerHTML = `<tr><td colspan="7" class="loading-text">加载中...</td></tr>`;
                recommendList.innerHTML = `<div class="recommend-empty">加载数据中...</div>`;
            }

            try {
                const raw = await fetchData();
                const parsed = parseApiData(raw);

                if (!parsed || parsed.length === 0) {
                    throw new Error('解析后无有效数据');
                }

                // 按期号降序排序（最新在前）
                parsed.sort((a, b) => parseIssueNum(b.issue) - parseIssueNum(a.issue));

                allData = parsed;
                latestItem = allData.length > 0 ? allData[0] : null;

                // 更新UI
                renderLatest(latestItem);
                renderHistory(allData);
                renderRecommendations(allData);

                statusData.textContent = `数据来源：${allData.length} 期`;
                statusTime.textContent = `更新：${getNowStr()}`;
                headerTime.textContent = getNowStr();

            } catch (err) {
                console.error('加载失败', err);
                historyBody.innerHTML = `<tr><td colspan="7" class="error-text">❌ ${err.message || '加载失败，请重试'}</td></tr>`;
                recommendList.innerHTML = `<div class="recommend-empty">⚠️ 数据加载失败，请点击刷新重试</div>`;
                statusData.textContent = '数据来源：加载失败';
                statusTime.textContent = `更新：${getNowStr()}`;
                showToast('数据加载失败: ' + (err.message || '未知错误'), 2500);
            } finally {
                isRefreshing = false;
            }
        }

        // ============================================================
        //  启动 & 事件绑定
        // ============================================================

        // 刷新按钮
        document.getElementById('btnRefresh').addEventListener('click', function() {
            this.textContent = '刷新中...';
            this.disabled = true;
            loadData(true).finally(() => {
                this.textContent = '刷新';
                this.disabled = false;
            });
        });

        // 初始加载
        loadData(true);

        // 更新时间显示
        setInterval(() => {
            headerTime.textContent = getNowStr();
        }, 30000);

        console.log('🚀 PC28 智能预测已启动');
        console.log('📊 算法: 用户自定义提取 + 加法预测 (大小判定 >=14 为大)');
        console.log('📞 客服: @ero6v');

        // 暴露一些变量便于调试
        window.__app = {
            allData,
            latestItem,
            loadData,
            predictWithAlgorithm,
            getRecommendations,
            isTrendChaotic,
            CONFIG,
        };
    </script>

