        // ---- 音效 ----
        function playNotificationSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                oscillator.frequency.value = 880;
                oscillator.type = 'sine';
                gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
                oscillator.start(audioCtx.currentTime);
                oscillator.stop(audioCtx.currentTime + 0.3);
            } catch (e) {
                // 静默失败
            }
        }

        // ---- 胜率统计与历史记录 ----
        function recordPrediction(predictedForm, actualForm) {
            const now = new Date().toLocaleString('zh-CN');
            const hit = (predictedForm === actualForm);
            predictionHistory.unshift({
                time: now,
                predicted: predictedForm,
                actual: actualForm,
                hit: hit,
                userMark: null // 用户手动标记 'win' 或 'lose'
            });
            if (predictionHistory.length > 50) predictionHistory.pop();
            localStorage.setItem('predictionHistory', JSON.stringify(predictionHistory));
            updateHistoryUI();
            updateWinRates();
        }

        function updateHistoryUI() {
            const tbody = document.getElementById('historyBody');
            if (predictionHistory.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="color:var(--text-muted);">暂无记录</td></tr>';
                return;
            }
            let html = '';
            const recent = predictionHistory.slice(0, 10);
            recent.forEach((item, index) => {
                const status = item.hit ? '✅ 命中' : '❌ 未中';
                const cls = item.hit ? 'hit' : 'miss';
                const userMark = item.userMark ? (item.userMark === 'win' ? '✅ 用户标记中' : '❌ 用户标记不中') : '未标记';
                html += `<tr>
                    <td>${item.time}</td>
                    <td>${item.predicted}</td>
                    <td>${item.actual || '--'}</td>
                    <td class="${cls}">${status}</td>
                    <td>
                        <button class="btn" style="font-size:10px; padding:2px 6px;" onclick="markHistory(${index}, 'win')">✓</button>
                        <button class="btn" style="font-size:10px; padding:2px 6px;" onclick="markHistory(${index}, 'lose')">✗</button>
                        ${userMark}
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html;
        }

        function markHistory(index, mark) {
            if (index < 0 || index >= predictionHistory.length) return;
            predictionHistory[index].userMark = mark;
            localStorage.setItem('predictionHistory', JSON.stringify(predictionHistory));
            updateHistoryUI();
            updateWinRates();
        }

        function updateWinRates() {
            // 算法胜率（基于实际命中）
            const total = predictionHistory.filter(p => p.actual !== undefined && p.actual !== null && p.actual !== '--').length;
            const hits = predictionHistory.filter(p => p.hit === true).length;
            const algoRate = total > 0 ? (hits / total * 100).toFixed(1) : '0.0';
            document.getElementById('algoWinRate').textContent = algoRate + '%';

            // 用户胜率（基于用户标记）
            const marked = predictionHistory.filter(p => p.userMark !== null).length;
            const userHits = predictionHistory.filter(p => p.userMark === 'win').length;
            const userRate = marked > 0 ? (userHits / marked * 100).toFixed(1) : '0.0';
            document.getElementById('userWinRate').textContent = userRate + '%';
        }

