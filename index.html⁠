        // ---- 遗漏走势图 ----
        function updateMissTrend(records) {
            if (records.length < 10) return;
            const forms = ["大单", "大双", "小单", "小双"];
            const formMap = {};
            forms.forEach(f => formMap[f] = []);
            const recent = records.slice(0, 30);
            const labels = recent.map(r => r.expect).reverse();
            forms.forEach(f => {
                let lastSeen = -1;
                const data = [];
                for (let i = 0; i < recent.length; i++) {
                    if (recent[i].form === f) lastSeen = i;
                    const miss = lastSeen === -1 ? i : i - lastSeen;
                    data.push(miss);
                }
                formMap[f] = data.reverse();
            });

            const ctx = document.getElementById('missTrendChart').getContext('2d');
            if (missTrendChartInstance) missTrendChartInstance.destroy();
            missTrendChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: '大单', data: formMap['大单'], borderColor: '#ff4757', fill: false, tension: 0.2 },
                        { label: '大双', data: formMap['大双'], borderColor: '#ffa502', fill: false, tension: 0.2 },
                        { label: '小单', data: formMap['小单'], borderColor: '#1e90ff', fill: false, tension: 0.2 },
                        { label: '小双', data: formMap['小双'], borderColor: '#2ed573', fill: false, tension: 0.2 }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { labels: { font: { size: 10 } } } },
                    scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } }
                }
            });
        }

        // ---- 和值分布饼图 ----
        function updateSumDist(records) {
            if (records.length < 10) return;
            const recent = records.slice(0, 30);
            const ranges = { '0-5': 0, '6-10': 0, '11-15': 0, '16-20': 0, '21-27': 0 };
            recent.forEach(r => {
                const num = r.num;
                if (num <= 5) ranges['0-5']++;
                else if (num <= 10) ranges['6-10']++;
                else if (num <= 15) ranges['11-15']++;
                else if (num <= 20) ranges['16-20']++;
                else ranges['21-27']++;
            });
            const ctx = document.getElementById('sumDistChart').getContext('2d');
            if (sumDistChartInstance) sumDistChartInstance.destroy();
            sumDistChartInstance = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: Object.keys(ranges),
                    datasets: [{ data: Object.values(ranges), backgroundColor: ['#ff4757', '#ffa502', '#1e90ff', '#2ed573', '#a29bfe'] }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } } } }
            });
        }

        // ---- 奇偶/大小比例 ----
