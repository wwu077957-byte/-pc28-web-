        requestNotificationPermission();

        // ============================================================
        // 4. PC28 核心逻辑（完整）
        // ============================================================
        let pc28Records = [];
        let trendChart = null, heatmapChart = null, missTrendChart = null, sumDistChart = null, ratioChart = null;
        let predictionHistory = JSON.parse(localStorage.getItem('predictionHistory')) || [];

        function generateThreeDigits(total) {
            for (let i=0; i<100; i++) { let a=Math.floor(Math.random()*10), b=Math.floor(Math.random()*10), c=Math.floor(Math.random()*10); if (a+b+c===total) return [a,b,c]; }
            let a=Math.min(9,total), b=Math.min(9,total-a), c=total-a-b;
            if (c>9) { c=9; a=total-b-c; if (a<0) a=0; }
            return [a,b,c];
        }

        function classifyRecord(r) {
            let digits = generateThreeDigits(r.num);
            let size = r.num >= 14 ? "大" : "小";
            let parity = r.num % 2 === 1 ? "单" : "双";
            return { expect: r.expect, num: r.num, digits, size, parity, form: size + parity };
        }

        function getWMAParams() { return parseInt(document.getElementById('wmaWindowSlider').value); }
        function getMarkovOrder() { return parseInt(document.getElementById('markovOrderSlider').value); }

        // ---- 算法 ----
        function algoThreeStep(records) {
            if (records.length<3) return null;
            let n1=records[0], n2=records[1], n3=records[2];
            let X=Math.floor(n1.num/10), Y=n2.digits[0]||0, Z=n3.digits[2]||0;
            let mid=X+Y+Z, pred=mid+n1.num;
            let size=pred>=14?"大":"小", parity=pred%2===1?"单":"双";
            return { form: size+parity, predVal: pred, details: `X=${X},Y=${Y},Z=${Z},中间值=${mid},预测值=${pred}` };
        }

        function algoWMA(records, window) {
            if (!window) window = getWMAParams();
            if (records.length < window) return null;
            let nums = records.slice(0, window).map(r => r.num);
            let weights = Array.from({length: window}, (_,i) => i+1);
            let wma = nums.reduce((s,n,i) => s + n*weights[i], 0) / weights.reduce((a,b) => a+b, 0);
            let size = wma >= 14 ? "大" : "小";
            let parity = Math.round(wma) % 2 === 1 ? "单" : "双";
            return { form: size+parity, predVal: wma, details: `WMA=${wma.toFixed(2)}` };
        }

        function algoMarkov(records, order) {
            if (!order) order = getMarkovOrder();
            if (records.length < 10) return null;
            let forms = records.map(r => r.form), states = ["大单","大双","小单","小双"], trans = {};
            states.forEach(s => trans[s] = {});
            for (let i=0; i<forms.length-order; i++) {
                let cur=forms[i], nxt=forms[i+order];
                if (states.includes(cur) && states.includes(nxt)) trans[cur][nxt] = (trans[cur][nxt]||0)+1;
            }
            let last = forms[0];
            if (!trans[last] || Object.keys(trans[last]).length===0) return null;
            let total = Object.values(trans[last]).reduce((a,b)=>a+b,0);
            let max=0, maxF=null;
            for (let f in trans[last]) { if (trans[last][f] > max) { max = trans[last][f]; maxF = f; } }
            return { form: maxF, predVal: null, details: `${last}→${maxF} (${(max/total*100).toFixed(1)}%)` };
        }

        function algoEnsemble(records) {
            let r = [algoThreeStep(records), algoWMA(records), algoMarkov(records)].filter(x => x);
            if (r.length === 0) return null;
            let cnt = {};
            r.forEach(x => cnt[x.form] = (cnt[x.form]||0)+1);
            let max=0, maxF=null; for (let f in cnt) { if (cnt[f] > max) { max = cnt[f]; maxF = f; } }
            return { form: maxF, predVal: null, details: `综合${r.length}种算法` };
        }

        // ---- 统计推荐 ----
        function getStatRecommendations(records) {
            if (records.length < 10) return ["大单","大双","小单"];
            let recent = records.slice(0,30);
            let forms = recent.map(r => r.form), cnt = {};
            forms.forEach(f => cnt[f] = (cnt[f]||0)+1);
            let sorted = Object.entries(cnt).sort((a,b) => b[1] - a[1]);
            let main = sorted[0][0];
            let rec2 = sorted[1] ? sorted[1][0] : (main === "大单" ? "大双" : "大单");
            let rec3 = sorted[2] ? sorted[2][0] : (main === "大单" ? "小单" : "小双");
            return [main, rec2, rec3];
        }

        function getKillRecommendation(formCnt, total) {
            if (Object.keys(formCnt).length === 0) return ["大单", 0];
            let minForm = null, minCnt = Infinity;
            for (let f in formCnt) { if (formCnt[f] < minCnt) { minCnt = formCnt[f]; minForm = f; } }
            return [minForm, minCnt / total * 100];
        }

        function getHotColdNumbers(records) {
            let freq = Array(28).fill(0);
            records.forEach(r => { if (r.num >= 0 && r.num <= 27) freq[r.num]++; });
            let sorted = freq.map((v,i) => ({num:i, count:v})).filter(f => f.count > 0).sort((a,b) => b.count - a.count);
            return { hot: sorted.slice(0,5).map(f=>f.num), cold: sorted.slice(-5).map(f=>f.num) };
        }

        function getConsecutiveStats(records) {
            if (records.length < 2) return { size:0, parity:0, form:0, sizeChar:'', parityChar:'', formChar:'' };
            let sizes = records.map(r => r.size), parities = records.map(r => r.parity), forms = records.map(r => r.form);
            let sizeRun=1, parityRun=1, formRun=1;
            for (let i=1; i<sizes.length; i++) { if (sizes[i] === sizes[0]) sizeRun++; else break; }
            for (let i=1; i<parities.length; i++) { if (parities[i] === parities[0]) parityRun++; else break; }
            for (let i=1; i<forms.length; i++) { if (forms[i] === forms[0]) formRun++; else break; }
            return { size: sizeRun, parity: parityRun, form: formRun, sizeChar: sizes[0], parityChar: parities[0], formChar: forms[0] };
        }

        function analyzeRecords(records, limit=30) {
            if (records.length < 10) return null;
            let recent = records.slice(0, limit);
            let sizes = recent.map(r => r.size), parities = recent.map(r => r.parity), forms = recent.map(r => r.form);
            let sizeCnt={}, parityCnt={}, formCnt={};
            sizes.forEach(s => sizeCnt[s] = (sizeCnt[s]||0)+1);
            parities.forEach(p => parityCnt[p] = (parityCnt[p]||0)+1);
            forms.forEach(f => formCnt[f] = (formCnt[f]||0)+1);
            return { sizeCnt, parityCnt, formCnt, total: recent.length };
        }

        // ---- 音效 ----
        function playSound() {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const o = ctx.createOscillator(), g = ctx.createGain();
                o.connect(g); g.connect(ctx.destination);
                o.frequency.value = 880; o.type = 'sine';
                g.gain.setValueAtTime(0.08, ctx.currentTime);
                g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
                o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.25);
            } catch(e) {}
        }

        // ---- 历史记录 ----
        function recordPrediction(predicted, actual) {
            const now = new Date().toLocaleString('zh-CN');
            predictionHistory.unshift({ time: now, predicted, actual, hit: (predicted === actual), userMark: null });
            if (predictionHistory.length > 50) predictionHistory.pop();
            localStorage.setItem('predictionHistory', JSON.stringify(predictionHistory));
            updateHistoryUI(); updateWinRates();
        }

        function updateHistoryUI() {
            const tbody = document.getElementById('historyBody');
            if (predictionHistory.length === 0) { tbody.innerHTML = '<tr><td colspan="5" style="color:var(--text-muted);">暂无记录</td></tr>'; return; }
            let html = '';
            predictionHistory.slice(0,10).forEach((item,index) => {
                const status = item.hit ? '✅ 命中' : '❌ 未中';
                const cls = item.hit ? 'hit' : 'miss';
                const userMark = item.userMark ? (item.userMark === 'win' ? '✅ 标记中' : '❌ 标记不中') : '未标记';
                html += `<tr><td>${item.time}</td><td>${item.predicted}</td><td>${item.actual || '--'}</td><td class="${cls}">${status}</td><td><button class="btn btn-small" onclick="markHistory(${index},'win')">✓</button><button class="btn btn-small" onclick="markHistory(${index},'lose')">✗</button> ${userMark}</td></tr>`;
            });
            tbody.innerHTML = html;
        }

        function markHistory(index, mark) {
            if (index<0 || index>=predictionHistory.length) return;
            predictionHistory[index].userMark = mark;
            localStorage.setItem('predictionHistory', JSON.stringify(predictionHistory));
            updateHistoryUI(); updateWinRates();
        }

        function updateWinRates() {
            const total = predictionHistory.filter(p => p.actual && p.actual !== '--').length;
            const hits = predictionHistory.filter(p => p.hit === true).length;
            const algoRate = total > 0 ? (hits / total * 100).toFixed(1) : '0.0';
            document.getElementById('algoWinRate').textContent = algoRate + '%';
            const marked = predictionHistory.filter(p => p.userMark !== null).length;
            const userHits = predictionHistory.filter(p => p.userMark === 'win').length;
            const userRate = marked > 0 ? (userHits / marked * 100).toFixed(1) : '0.0';
            document.getElementById('userWinRate').textContent = userRate + '%';
        }

        function resetHistory() {
            if (confirm('确定清除所有预测历史吗？')) { predictionHistory = []; localStorage.removeItem('predictionHistory'); updateHistoryUI(); updateWinRates(); }
        }

        // ---- 图表更新 ----
        function updateCharts(records) {
            // 趋势图
            const nums = records.slice(0,20).map(r => r.num).reverse();
            const labels = records.slice(0,20).map(r => r.expect).reverse();
            const ctxTrend = document.getElementById('trendChart').getContext('2d');
            if (trendChart) trendChart.destroy();
            trendChart = new Chart(ctxTrend, {
                type: 'line',
                data: { labels, datasets: [{ label: '和值', data: nums, borderColor: '#f7971e', backgroundColor: 'rgba(247,151,30,0.1)', tension: 0.2, fill: true, pointRadius: 3 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 27, grid: { color: 'rgba(255,255,255,0.05)' } }, x: { grid: { display: false } } } }
            });
            if (records.length >= 3) {
                const pred = algoThreeStep(records);
                if (pred && pred.predVal !== null) {
                    const ext = [...nums.slice(0,-1), pred.predVal];
                    trendChart.data.datasets.push({ label: '预测趋势', data: ext, borderColor: '#ff0000', borderDash: [6,4], borderWidth: 2, pointRadius: 0, fill: false, tension: 0.2 });
                    trendChart.update();
                }
            }

            // 热力图
            const freq = Array(28).fill(0);
            records.forEach(r => { if (r.num>=0 && r.num<=27) freq[r.num]++; });
            const ctxHeat = document.getElementById('heatmapChart').getContext('2d');
            if (heatmapChart) heatmapChart.destroy();
            heatmapChart = new Chart(ctxHeat, {
                type: 'bar',
                data: { labels: Array.from({length:28},(_,i)=>i), datasets: [{ label: '出现次数', data: freq, backgroundColor: freq.map(v => `rgba(247,151,30,${0.3 + Math.min(1,v/10)*0.7})`), borderColor: '#f7971e', borderWidth: 1 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' } }, x: { grid: { display: false } } } }
            });
        }

        function updateMissTrend(records) {
            if (records.length < 10) return;
            const forms = ["大单","大双","小单","小双"], formMap = {};
            forms.forEach(f => formMap[f] = []);
            const recent = records.slice(0,30), labels = recent.map(r => r.expect).reverse();
            forms.forEach(f => {
                let lastSeen = -1;
                const data = [];
                for (let i=0; i<recent.length; i++) {
                    if (recent[i].form === f) lastSeen = i;
                    data.push(lastSeen === -1 ? i : i - lastSeen);
                }
                formMap[f] = data.reverse();
            });
            const ctx = document.getElementById('missTrendChart').getContext('2d');
            if (missTrendChart) missTrendChart.destroy();
            missTrendChart = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets: [
                    { label: '大单', data: formMap['大单'], borderColor: '#ff4757', fill: false, tension: 0.2 },
                    { label: '大双', data: formMap['大双'], borderColor: '#ffa502', fill: false, tension: 0.2 },
                    { label: '小单', data: formMap['小单'], borderColor: '#1e90ff', fill: false, tension: 0.2 },
                    { label: '小双', data: formMap['小双'], borderColor: '#2ed573', fill: false, tension: 0.2 }
                ]},
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { font: { size: 10 } } } }, scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } } }
            });
        }

        function updateSumDist(records) {
            if (records.length < 10) return;
            const recent = records.slice(0,30);
            const ranges = { '0-5':0, '6-10':0, '11-15':0, '16-20':0, '21-27':0 };
            recent.forEach(r => { const n = r.num; if (n<=5) ranges['0-5']++; else if (n<=10) ranges['6-10']++; else if (n<=15) ranges['11-15']++; else if (n<=20) ranges['16-20']++; else ranges['21-27']++; });
            const ctx = document.getElementById('sumDistChart').getContext('2d');
            if (sumDistChart) sumDistChart.destroy();
            sumDistChart = new Chart(ctx, {
                type: 'pie',
                data: { labels: Object.keys(ranges), datasets: [{ data: Object.values(ranges), backgroundColor: ['#ff4757','#ffa502','#1e90ff','#2ed573','#a29bfe'] }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } } } }
            });
        }

        function updateRatio(records) {
            if (records.length < 10) return;
            const recent = records.slice(0,30);
            const big = recent.filter(r => r.num >= 14).length, small = recent.length - big;
            const odd = recent.filter(r => r.num % 2 === 1).length, even = recent.length - odd;
            const ctx = document.getElementById('ratioChart').getContext('2d');
            if (ratioChart) ratioChart.destroy();
            ratioChart = new Chart(ctx, {
                type: 'bar',
                data: { labels: ['大','小','单','双'], datasets: [{ label: '出现次数', data: [big, small, odd, even], backgroundColor: ['#ff4757','#1e90ff','#2ed573','#ffa502'] }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } } }
            });
        }

        function updateDetailTable(records) {
            const tbody = document.getElementById('detailBody');
            if (records.length === 0) { tbody.innerHTML = '<tr><td colspan="5" style="color:var(--text-muted);">暂无数据</td></tr>'; return; }
            let html = '';
            records.slice(0,10).forEach(r => {
                const d = r.digits ? `${r.digits[0]},${r.digits[1]},${r.digits[2]}` : '--';
                html += `<tr><td>${r.expect}</td><td>${r.num}</td><td>${r.size || '--'}</td><td>${r.parity || '--'}</td><td>${d}</td></tr>`;
            });
            tbody.innerHTML = html;
        }

        function updateTransitionTip(records) {
            if (records.length < 2) { document.getElementById('transitionTip').textContent = '数据不足'; return; }
            const forms = records.map(r => r.form), trans = {};
            for (let i=0; i<forms.length-1; i++) {
                const cur = forms[i], nxt = forms[i+1];
                if (!trans[cur]) trans[cur] = {};
                trans[cur][nxt] = (trans[cur][nxt]||0)+1;
            }
            const last = forms[0];
            if (!trans[last] || Object.keys(trans[last]).length===0) { document.getElementById('transitionTip').textContent = '暂无转换数据'; return; }
            let max=0, maxF=null;
            for (let f in trans[last]) { if (trans[last][f] > max) { max = trans[last][f]; maxF = f; } }
            const total = Object.values(trans[last]).reduce((a,b)=>a+b,0);
            document.getElementById('transitionTip').textContent = `当前形态 ${last} → 最可能 ${maxF} (概率 ${(max/total*100).toFixed(1)}%)`;
        }

        function updateBetSuggestion(records) {
            if (records.length < 10) { document.getElementById('betSuggestion').innerHTML = '数据不足'; return; }
            const stats = analyzeRecords(records);
            if (!stats) { document.getElementById('betSuggestion').innerHTML = '统计失败'; return; }
            const [rec1, rec2, rec3] = getStatRecommendations(stats);
            const kill = getKillRecommendation(stats.formCnt, stats.total)[0];
            document.getElementById('betSuggestion').innerHTML =
                `<span>⭐ 主推：<strong style="color:var(--theme-color);">${rec1}</strong></span>
                 <span>🔹 次推：<strong style="color:var(--theme-color);">${rec2}</strong></span>
                 <span>🛡 补防：<strong style="color:var(--theme-color);">${rec3}</strong></span>
                 <span>❌ 杀号：<strong style="color:#ff4757;">${kill}</strong></span>`;
        }

        function updateHotColdConsecutive(records) {
            if (!records || records.length===0) return;
            const { hot, cold } = getHotColdNumbers(records);
            document.getElementById('hotNumbers').innerHTML = hot.map(n => `<span class="hot">${n}</span>`).join('');
            document.getElementById('coldNumbers').innerHTML = cold.map(n => `<span class="cold">${n}</span>`).join('');
            const cs = getConsecutiveStats(records);
            if (cs.size > 0) document.getElementById('consecutiveStats').innerHTML = `大小连出 ${cs.size}期 (${cs.sizeChar}) | 单双连出 ${cs.parity}期 (${cs.parityChar}) | 形态连出 ${cs.form}期 (${cs.formChar})`;
            else document.getElementById('consecutiveStats').textContent = '--';
        }

        // ---- 渲染 ----
        function render() {
            const area = document.getElementById('resultArea');
            if (pc28Records.length < 3) { area.innerHTML = '数据不足3期'; return; }
            const records = pc28Records.map(r => classifyRecord(r));
            const algoType = document.getElementById('algoSelect').value;
            let result = null;
            switch(algoType) {
                case 'three_step': result = algoThreeStep(records); break;
                case 'wma': result = algoWMA(records); break;
                case 'markov': result = algoMarkov(records); break;
                case 'ensemble': result = algoEnsemble(records); break;
                default: result = algoThreeStep(records);
            }
            const latest = records.slice(0,3);
            const [rec1, rec2, rec3] = getStatRecommendations(records);
            let html = '';
            html += '<div style="font-weight:600;margin-bottom:8px;">📈 最近3期数据</div>';
            latest.forEach(r => {
                html += `<div class="row"><span class="label">${r.expect}</span><span class="value">${r.num}（${r.size}${r.parity}）</span><span style="color:var(--text-muted);">${r.digits[0]},${r.digits[1]},${r.digits[2]}</span></div>`;
            });
            const algoName = document.getElementById('algoSelect').options[document.getElementById('algoSelect').selectedIndex].text;
            html += `<div style="font-weight:600;margin:12px 0 8px;">🧮 当前算法：${algoName}</div>`;
            if (result) {
                html += `<div class="row"><span class="label">预测值</span><span style="font-weight:700;">${result.predVal !== null ? result.predVal : '--'}</span></div>`;
                html += `<div class="row"><span class="label">预测形态</span><span style="font-weight:700;color:var(--theme-color);">${result.form}</span></div>`;
                html += `<div class="row"><span class="label">详情</span><span style="font-size:13px;color:var(--text-muted);">${result.details}</span></div>`;
            } else {
                html += `<div style="color:var(--text-muted);">算法所需数据不足</div>`;
            }
            html += `<div style="font-weight:600;margin:12px 0 8px;">🎯 统计推荐</div>`;
            html += `<div class="rec-card rec-main">⭐ 主推：${rec1}</div>`;
            html += `<div class="rec-card">🔹 次推：${rec2}</div>`;
            html += `<div class="rec-card">🛡 补防：${rec3}</div>`;
            area.innerHTML = html;
            // 记录历史（记录主推）
            if (result && result.form && latest.length>0 && latest[0].form) {
                recordPrediction(result.form, latest[0].form);
            }
            // 更新其他
            updateCharts(records);
            updateHotColdConsecutive(records);
            updateMissTrend(records);
            updateSumDist(records);
            updateRatio(records);
            updateDetailTable(records);
            updateTransitionTip(records);
            updateBetSuggestion(records);
        }

        // ---- 获取数据 ----
        async function fetchData() {
            const area = document.getElementById('resultArea');
            area.innerHTML = '<div class="spinner"></div> 加载数据中...';
            try {
                const resp = await fetch('https://pc28.help/api/kj.json?nbr=20');
                const json = await resp.json();
                if (json && json.data && json.data.length > 0) {
                    pc28Records = json.data.map(item => ({ expect: item.nbr, num: parseInt(item.num) }));
                    pc28Records.sort((a,b) => parseInt(b.expect) - parseInt(a.expect));
                } else {
                    pc28Records = [
                        { expect:"3444534", num:19 }, { expect:"3444533", num:9 },
                        { expect:"3444532", num:14 }, { expect:"3444531", num:12 },
                        { expect:"3444530", num:16 }, { expect:"3444529", num:8 },
                        { expect:"3444528", num:11 }, { expect:"3444527", num:6 },
                        { expect:"3444526", num:18 }, { expect:"3444525", num:15 }
                    ];
                }
            } catch(e) {
                pc28Records = [
                    { expect:"3444534", num:19 }, { expect:"3444533", num:9 },
                    { expect:"3444532", num:14 }, { expect:"3444531", num:12 },
                    { expect:"3444530", num:16 }, { expect:"3444529", num:8 },
                    { expect:"3444528", num:11 }, { expect:"3444527", num:6 },
                    { expect:"3444526", num:18 }, { expect:"3444525", num:15 }
                ];
            }
            document.getElementById('dataCount').textContent = `数据期数：${pc28Records.length}`;
            document.getElementById('statusBadge').textContent = '● 在线';
            document.getElementById('statusBadge').style.color = '#28a745';
            render();
            document.getElementById('updateTime').textContent = new Date().toLocaleString('zh-CN');
            playSound();
        }

        function manualRefresh() {
            if (pc28Records.length > 0) {
                render();
                countdownSeconds = 60;
                document.getElementById('countdownDisplay').textContent = '60秒';
            } else {
                fetchData();
            }
        }

        document.getElementById('algoSelect').addEventListener('change', function() { if (pc28Records.length > 0) render(); });
        document.getElementById('wmaWindowSlider').addEventListener('input', function() {
            document.getElementById('wmaWindowDisplay').textContent = this.value;
            if (pc28Records.length > 0) { render(); }
        });
        document.getElementById('markovOrderSlider').addEventListener('input', function() {
            document.getElementById('markovOrderDisplay').textContent = this.value;
            if (pc28Records.length > 0) { render(); }
        });

        // ============================================================
        // 5. 网速测试
        // ============================================================
        async function testSpeed() {
            const status = document.getElementById('speedStatus');
            status.textContent = '测速中...';
            if ('connection' in navigator) {
                const conn = navigator.connection;
                const down = (conn.downlink || 0).toFixed(1);
                document.getElementById('downloadSpeed').textContent = down;
                document.getElementById('uploadSpeed').textContent = (down * 0.8).toFixed(1);
                status.textContent = '✅ 测速完成 (估算值)';
                return;
            }
            try {
                const start = Date.now();
                await fetch('https://www.google.com/images/phd/px.gif?t=' + Date.now(), { mode: 'no-cors' });
                const duration = (Date.now() - start) / 1000;
                const speed = (10 * 8) / (duration * 1024);
                const d = Math.max(0.1, speed).toFixed(1);
                document.getElementById('downloadSpeed').textContent = d;
                document.getElementById('uploadSpeed').textContent = (d * 0.8).toFixed(1);
                status.textContent = '✅ 测速完成 (估算)';
            } catch(e) {
                document.getElementById('downloadSpeed').textContent = '--';
                document.getElementById('uploadSpeed').textContent = '--';
                status.textContent = '❌ 测速失败';
            }
        }

        // ============================================================
        // 6. 汇率换算
        // ============================================================
        async function convertCurrency() {
            const from = document.getElementById('currencyFrom').value;
            const amount = parseFloat(document.getElementById('currencyAmount').value) || 1;
            const resultDiv = document.getElementById('currencyResult');
            resultDiv.textContent = '换算中...';
            try {
                const resp = await fetch('https://api.exchangerate.host/latest?base=USD&symbols=CNY');
                const data = await resp.json();
                let rateCNY = 7.23;
                if (data && data.rates && data.rates.CNY) rateCNY = data.rates.CNY;
                const rates = { USDT: 1 * rateCNY, TON: 5.67 * rateCNY, BTC: 65000 * rateCNY, ETH: 3500 * rateCNY, USD: 1 * rateCNY, EUR: 0.93 * rateCNY };
                const result = amount * rates[from];
                resultDiv.textContent = result.toFixed(2) + ' 人民币';
            } catch(e) {
                const rates = { USDT: 7.23, TON: 5.67, BTC: 65000, ETH: 3500, USD: 1, EUR: 0.93 };
                const result = amount * rates[from] * 7.23;
                resultDiv.textContent = result.toFixed(2) + ' 人民币 (估算)';
            }
        }

        // ============================================================
        // 7. USDT & TON 查询
        // ============================================================
        async function queryUSDT() {
            const address = document.getElementById('usdtAddress').value.trim();
            const resultDiv = document.getElementById('usdtResult');
            if (!address) { resultDiv.textContent = '⚠️ 请输入地址'; return; }
            resultDiv.innerHTML = '<div class="spinner"></div> 查询中...';
            try {
                const resp = await fetch(`https://api.trongrid.io/v1/accounts/${address}/trc20/balance?contract_address=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t`);
                const data = await resp.json();
                let balance = '0';
                if (data.data && data.data.length > 0) balance = (parseInt(data.data[0].balance) / 1e6).toFixed(2);
                resultDiv.textContent = `💰 余额：${balance} USDT`;
            } catch(e) {
                resultDiv.textContent = '❌ 查询失败，请稍后重试';
            }
        }

        async function queryTON() {
            const address = document.getElementById('tonAddress').value.trim();
            const resultDiv = document.getElementById('tonResult');
            if (!address) { resultDiv.textContent = '⚠️ 请输入地址'; return; }
            resultDiv.innerHTML = '<div class="spinner"></div> 查询中...';
            try {
                const resp = await fetch(`https://tonapi.io/v2/accounts/${address}`);
                const data = await resp.json();
                const balance = data.balance ? (parseInt(data.balance) / 1e9).toFixed(2) : '0';
                resultDiv.textContent = `💎 余额：${balance} TON`;
            } catch(e) {
                resultDiv.textContent = '❌ 查询失败，请稍后重试';
            }
        }

        // ============================================================
        // 8. 分享截图
        // ============================================================
        function sharePrediction() {
            html2canvas(document.querySelector('.container')).then(canvas => {
                canvas.toBlob(function(blob) {
                    if (navigator.share) {
                        navigator.share({ title: 'PC28预测结果', files: [new File([blob], 'prediction.png', { type: 'image/png' })] }).catch(() => {});
                    } else {
                        const link = document.createElement('a');
                        link.download = 'prediction.png';
                        link.href = canvas.toDataURL();
                        link.click();
                    }
                });
            });
        }

        // ============================================================
        // 9. 初始化
        // ============================================================
        fetchData();
        setTimeout(testSpeed, 1500);
        updateHistoryUI();
        updateWinRates();

        // 导出部分函数供全局使用（用于按钮事件）
        window.fetchData = fetchData;
        window.manualRefresh = manualRefresh;
        window.testSpeed = testSpeed;
        window.convertCurrency = convertCurrency;
        window.queryUSDT = queryUSDT;
        window.queryTON = queryTON;
        window.sharePrediction = sharePrediction;
        window.toggleTheme = toggleTheme;
        window.resetHistory = resetHistory;
        window.markHistory = markHistory;
    </script>
</body>
</html>
