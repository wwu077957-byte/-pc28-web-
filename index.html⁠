        // 重写 WMA 函数，使用参数
        function algoWMA(records, window = null) {
            if (!window) window = getWMAParams();
            if (records.length < window) return null;
            let nums = records.slice(0, window).map(r => r.num);
            let weights = Array.from({ length: window }, (_, i) => i + 1);
            let wma = nums.reduce((sum, n, i) => sum + n * weights[i], 0) / weights.reduce((a, b) => a + b, 0);
            let size = wma >= 14 ? "大" : "小";
            let parity = Math.round(wma) % 2 === 1 ? "单" : "双";
            return { form: size + parity, predVal: wma, details: `加权移动平均=${wma.toFixed(2)}` };
        }

        // 重写马尔可夫，支持阶数
        function algoMarkov(records, order = null) {
            if (!order) order = getMarkovOrder();
            if (records.length < 10) return null;
            let forms = records.map(r => r.form);
            let states = ["大单", "大双", "小单", "小双"];
            let trans = {};
            states.forEach(s => trans[s] = {});
            for (let i = 0; i < forms.length - order; i++) {
                let cur = forms[i];
                let nxt = forms[i + order];
                if (states.includes(cur) && states.includes(nxt)) {
                    trans[cur][nxt] = (trans[cur][nxt] || 0) + 1;
                }
            }
            let lastForm = forms[0];
            if (!trans[lastForm] || Object.keys(trans[lastForm]).length === 0) return null;
            let total = Object.values(trans[lastForm]).reduce((a, b) => a + b, 0);
            let maxCount = 0, maxForm = null;
            for (let f in trans[lastForm]) {
                if (trans[lastForm][f] > maxCount) { maxCount = trans[lastForm][f]; maxForm = f; }
            }
            if (!maxForm) return null;
            return { form: maxForm, predVal: null, details: `从 ${lastForm} → ${maxForm} (概率 ${(maxCount/total*100).toFixed(1)}%)` };
        }

        // 其他算法（三步、综合）保持不变，但综合需调用上述参数化函数
        function algoEnsemble(records) {
            let results = [];
            let r1 = algoThreeStep(records);
            let r2 = algoWMA(records);
            let r3 = algoMarkov(records);
            if (r1) results.push(r1.form);
            if (r2) results.push(r2.form);
            if (r3) results.push(r3.form);
            if (results.length === 0) return null;
            let count = {};
            results.forEach(f => count[f] = (count[f] || 0) + 1);
            let maxCount = 0, maxForm = null;
            for (let f in count) {
                if (count[f] > maxCount) { maxCount = count[f]; maxForm = f; }
            }
            return { form: maxForm, predVal: null, details: `综合 ${results.length} 种算法，最多票 ${maxForm}` };
        }

